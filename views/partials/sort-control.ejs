<%
  /* Kontrol "Urutkan berdasarkan" yang dipakai bersama oleh halaman daftar.
     Locals yang diharapkan:
       - action : URL tujuan form (mis. '/purchase')
       - current: kunci sort aktif
       - opts   : array { v, l } (value & label opsi)
       - keep   : objek field tersembunyi yang dipertahankan (mis. { search: '...' })
     Pakai GET biasa; saat opsi diganti, form langsung dikirim. */
  const _keep = (typeof keep !== 'undefined' && keep) ? keep : {};
%>
<form method="get" action="<%= action %>" class="flex items-center gap-2 shrink-0">
  <% Object.keys(_keep).forEach(function (k) { %>
    <input type="hidden" name="<%= k %>" value="<%= _keep[k] %>" />
  <% }) %>
  <label for="sort-select" class="text-xs text-muted-foreground whitespace-nowrap">Urutkan</label>
  <select id="sort-select" name="sort" class="select" style="width:auto;" onchange="this.form.submit()">
    <% opts.forEach(function (o) { %>
      <option value="<%= o.v %>" <%= current === o.v ? 'selected' : '' %>><%= o.l %></option>
    <% }) %>
  </select>
</form>
