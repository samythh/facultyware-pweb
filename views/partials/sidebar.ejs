<script>
  (() => {
    document.addEventListener("DOMContentLoaded", () => {
      const sidebar = document.getElementById("sidebar");
      if (!sidebar) return;

      const updateCurrentLinks = () => {
        const currentPath = window.location.pathname.replace(/\/$/, "");
        const currentSearch = window.location.search;
        const currentKey = `${currentPath}${currentSearch}`;

        sidebar.querySelectorAll("a, button").forEach((item) => {
          const href = item.getAttribute("href");
          if (!href) {
            item.removeAttribute("aria-current");
            return;
          }

          const url = new URL(href, window.location.origin);
          const itemPath = url.pathname.replace(/\/$/, "");
          const itemKey = `${itemPath}${url.search}`;

          if (itemKey === currentKey || (itemPath === '/procurement' && currentPath.startsWith('/procurement')) || (itemPath === '/pengadaan' && currentPath.startsWith('/pengadaan'))) {
            item.setAttribute("aria-current", "page");
          } else {
            item.removeAttribute("aria-current");
          }
        });
      };

      document.addEventListener("htmx:afterSettle", updateCurrentLinks);
      window.addEventListener("popstate", updateCurrentLinks);
      updateCurrentLinks();
    });
  })();
</script>

<aside id="sidebar" class="sidebar" data-side="left" aria-hidden="false">
  <nav aria-label="Sidebar navigation">
    <header>
      <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
        <div class="flex aspect-square size-8 items-center justify-center">
          <img src="/img/logo-unand.png" alt="Logo Universitas Andalas" class="h-full w-full object-contain" />
        </div>
        <div class="grid flex-1 text-left text-sm leading-tight">
          <span class="truncate font-medium">Facultyware</span>
          <span class="truncate text-xs">PWEB Kelompok B09</span>
        </div>
      </a>
    </header>

    <section class="scrollbar [&amp;_[data-new-link]::after]:content-[&#39;New&#39;] [&amp;_[data-new-link]::after]:ml-auto [&amp;_[data-new-link]::after]:text-xs [&amp;_[data-new-link]::after]:font-medium [&amp;_[data-new-link]::after]:bg-sidebar-primary [&amp;_[data-new-link]::after]:text-sidebar-primary-foreground [&amp;_[data-new-link]::after]:px-2 [&amp;_[data-new-link]::after]:py-0.5 [&amp;_[data-new-link]::after]:rounded-md">
      <%
        // Helper izin untuk menu: tampilkan item hanya bila user punya permission.
        // `can` di-set global di app.js (res.locals.can) dari req.session.permissions.
        const canDo = (p) => (typeof can === 'function' ? can(p) : false);
      %>
      <div role="group" aria-labelledby="group-label-sidebar-content-1">
        <h3 id="group-label-sidebar-content-1">General</h3>
        <ul>
          <li>
            <a href="/dashboard" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
              </svg>
              <span>Dashboard</span>
            </a>
          </li>
        </ul>
      </div>

      <% if (canDo('manage_procurement') || canDo('manage_po') || canDo('manage_receiving') || canDo('manage_vendor')) { %>
      <div role="group" aria-labelledby="group-label-sidebar-content-inventory">
        <h3 id="group-label-sidebar-content-inventory">Inventory</h3>
        <ul>
          <% if (canDo('manage_procurement')) { %>
          <li>
            <a href="/procurement" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" y1="13" x2="8" y2="13" />
                <line x1="16" y1="17" x2="8" y2="17" />
                <polyline points="10 9 9 9 8 9" />
              </svg>
              <span>Permintaan Pengadaan</span>
            </a>
          </li>
          <% } %>
          <% if (canDo('manage_procurement')) { %>
          <li>
            <a href="/pengadaan" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                <line x1="8" y1="21" x2="16" y2="21" />
                <line x1="12" y1="17" x2="12" y2="21" />
              </svg>
              <span>Pengadaan Barang</span>
            </a>
          </li>
          <% } %>
          <% if (canDo('manage_po')) { %>
          <li>
            <a href="/purchase" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
              </svg>
              <span>Purchase Order</span>
            </a>
          </li>
          <% } %>
          <% if (canDo('manage_receiving')) { %>
          <li>
            <a href="/receiving" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                <line x1="12" y1="22.08" x2="12" y2="12" />
              </svg>
              <span>Penerimaan</span>
            </a>
          </li>
          <% } %>
          <% if (canDo('manage_vendor')) { %>
          <li>
            <a href="/supplier" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
              <span>Supplier</span>
            </a>
          </li>
          <% } %>
        </ul>
      </div>
      <% } %>

      <% if (canDo('manage_approval')) { %>
      <div role="group" aria-labelledby="group-label-sidebar-content-approval">
        <h3 id="group-label-sidebar-content-approval">Persetujuan</h3>
        <ul>
          <li>
            <a href="/approval/inbox" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-6l-2 3h-4l-2-3H2" />
                <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z" />
              </svg>
              <span>Persetujuan Permintaan</span>
            </a>
          </li>
          <li>
            <a href="/approval/po" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 1v22" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
              </svg>
              <span>Persetujuan Belanja (PO)</span>
            </a>
          </li>
          <li>
            <a href="/approval/history" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 8v13H3V8" />
                <path d="M1 3h22v5H1z" />
                <path d="M10 12h4" />
              </svg>
              <span>Arsip Pengadaan</span>
            </a>
          </li>
          <li>
            <a href="/approval/po/archive" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 12v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8" />
                <rect x="2" y="7" width="20" height="5" rx="1" />
                <path d="M12 22V7" />
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" />
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
              </svg>
              <span>Arsip PO</span>
            </a>
          </li>
        </ul>
      </div>
      <% } %>
    </section>

    <footer>
      <div class="flex items-center gap-2 p-2 mb-1">
        <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg font-bold shrink-0">
          <%= (typeof user !== 'undefined' && user) ? user.charAt(0).toUpperCase() : 'U' %>
        </div>
        <div class="grid flex-1 text-left text-sm leading-tight">
          <span class="truncate font-medium"><%= (typeof user !== 'undefined' && user) ? user : 'User' %></span>
          <span class="truncate text-xs text-muted-foreground">Sudah masuk</span>
        </div>
      </div>
      <a href="/logout" class="btn-outline w-full justify-center text-destructive hover:bg-destructive/10">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
          <polyline points="16 17 21 12 16 7" />
          <line x1="21" y1="12" x2="9" y2="12" />
        </svg>
        Logout
      </a>
    </footer>
  </nav>
</aside>
