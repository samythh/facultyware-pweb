<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="flex flex-col gap-2">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Daftar Purchase Order</h1>
          <p class="text-muted-foreground">Kelola purchase order ke pemasok.</p>
        </div>
        <a href="/purchase/create" class="btn">+ Buat PO</a>
      </header>

      <form method="get" action="/purchase" class="flex items-center gap-2">
        <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" placeholder="Cari supplier / nomor PO" class="input flex-1" />
        <button type="submit" class="btn-outline">Cari</button>
      </form>

      <div class="card">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-muted-foreground text-left">
                <th class="px-3 py-2 font-medium">No</th>
                <th class="px-3 py-2 font-medium">Nomor PO</th>
                <th class="px-3 py-2 font-medium">Supplier</th>
                <th class="px-3 py-2 font-medium">Tanggal</th>
                <th class="px-3 py-2 font-medium">Status</th>
                <th class="px-3 py-2 font-medium text-right">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (purchases && purchases.length) { %>
                <% purchases.forEach(function (po, idx) { %>
                  <tr class="border-t">
                    <td class="px-3 py-2"><%= idx + 1 %></td>
                    <td class="px-3 py-2 font-mono"><%= po.purchase_number %></td>
                    <td class="px-3 py-2"><%= po.supplier %></td>
                    <td class="px-3 py-2"><%= fmtDate(po.purchase_date) %></td>
                    <td class="px-3 py-2"><%- include('../partials/status-badge', { status: po.status }) %></td>
                    <td class="px-3 py-2 text-right">
                      <a href="/purchase/<%= po.id %>" class="btn-sm-outline">Detail</a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr class="border-t">
                  <td colspan="6" class="px-3 py-8 text-center text-muted-foreground">Belum ada Purchase Order.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
