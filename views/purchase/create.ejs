<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      <header class="flex flex-col gap-2">
        <a href="/purchase" class="text-sm text-muted-foreground hover:underline">&larr; Kembali ke daftar</a>
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Buat Purchase Order</h1>
      </header>

      <% if (locals.error) { %>
        <div class="card border-destructive p-4 text-destructive"><%= error %></div>
      <% } %>

      <form method="post" action="/purchase/create" class="card grid gap-6">
        <div class="grid gap-2">
          <label for="procurement_id">Permintaan (Approved)</label>
          <select name="inventory_procurement_id" id="procurement_id" class="select" required>
            <option value="">-- Pilih Permintaan --</option>
            <% procurements.forEach(function (p) { %>
              <option value="<%= p.id %>"><%= p.request_number %> - <%= p.title %></option>
            <% }) %>
          </select>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="grid gap-2">
            <label for="supplier">Supplier</label>
            <input type="text" id="supplier" name="supplier" class="input" required />
          </div>
          <div class="grid gap-2">
            <label for="purchase_date">Tanggal PO</label>
            <input type="date" id="purchase_date" name="purchase_date" class="input" required />
          </div>
        </div>

        <!-- Item dimuat dinamis setelah memilih permintaan -->
        <div id="procurement_items">
          <p class="text-muted-foreground text-sm">Pilih permintaan di atas untuk memuat daftar barang.</p>
        </div>

        <div class="flex items-center justify-end gap-3 border-t pt-4">
          <span class="text-sm text-muted-foreground">Total</span>
          <span id="total" class="text-lg font-bold">Rp 0</span>
        </div>

        <footer class="flex items-center justify-end gap-2">
          <a href="/purchase" class="btn-outline">Batal</a>
          <button type="submit" class="btn">Simpan PO</button>
        </footer>
      </form>
    </div>
  </div>
</main>

<script>
  document.getElementById('procurement_id').addEventListener('change', async function () {
    const id = this.value;
    const target = document.getElementById('procurement_items');
    target.innerHTML = '';
    if (!id) return;
    try {
      const res = await fetch(`/purchase/api/procurement/${id}/items`);
      if (!res.ok) throw new Error('fetch failed');
      const data = await res.json();
      if (!data.items || !data.items.length) {
        target.innerHTML = '<p class="text-muted-foreground text-sm py-3">Tidak ada item dalam permintaan ini.</p>';
        return;
      }
      const wrapper = document.createElement('div');
      wrapper.className = 'border rounded-lg p-4 space-y-2';
      wrapper.innerHTML = '<p class="text-sm font-semibold">Rincian Barang &amp; Harga</p>';
      const tableWrap = document.createElement('div');
      tableWrap.className = 'overflow-x-auto';
      const table = document.createElement('table');
      table.className = 'w-full text-sm';
      table.innerHTML = `
        <thead>
          <tr class="text-muted-foreground text-left">
            <th class="px-3 py-2 font-medium">Item</th>
            <th class="px-3 py-2 font-medium text-right">Qty</th>
            <th class="px-3 py-2 font-medium text-right">Harga</th>
            <th class="px-3 py-2 font-medium text-right">Subtotal</th>
          </tr>
        </thead>
        <tbody>
          ${data.items.map((i, idx) => `
            <tr class="border-t">
              <td class="px-3 py-2">${i.name}</td>
              <td class="px-3 py-2 text-right">${i.quantity}</td>
              <td class="px-3 py-2">
                <input type="number" name="prices[]" data-qty="${i.quantity}" min="0" class="input text-right" oninput="updateSubtotal()" />
              </td>
              <td id="subtotal-${idx}" class="px-3 py-2 text-right">Rp 0</td>
            </tr>`).join('')}
        </tbody>
      `;
      tableWrap.appendChild(table);
      wrapper.appendChild(tableWrap);
      target.appendChild(wrapper);
    } catch (e) {
      target.innerHTML = '<p class="text-destructive text-sm py-3">Gagal memuat items. Coba pilih ulang.</p>';
    }
  });

  function updateSubtotal() {
    const inputs = document.getElementsByName('prices[]');
    let total = 0;
    Array.from(inputs).forEach((inp, i) => {
      const qty = Number(inp.dataset.qty) || 0;
      const price = parseFloat(inp.value) || 0;
      const sub = qty * price;
      const cell = document.getElementById('subtotal-' + i);
      if (cell) cell.textContent = 'Rp ' + sub.toLocaleString('id-ID');
      total += sub;
    });
    document.getElementById('total').textContent = 'Rp ' + total.toLocaleString('id-ID');
  }
</script>

<%- include('../partials/footer') %>
