<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="flex flex-col gap-2">
          <a href="/purchase" class="text-sm text-muted-foreground hover:underline">&larr; Kembali ke daftar</a>
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Detail Purchase Order</h1>
        </div>
        <a href="/purchase/<%= po.id %>/export" class="btn-outline shrink-0">Cetak PDF</a>
      </header>

      <!-- Info PO -->
      <div class="card">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-wide text-muted-foreground">Nomor PO</span>
            <span class="font-semibold font-mono"><%= po.purchase_number %></span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-wide text-muted-foreground">Supplier</span>
            <span class="font-semibold"><%= po.supplier %></span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-wide text-muted-foreground">Tanggal</span>
            <span class="font-semibold"><%= fmtDate(po.purchase_date) %></span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-wide text-muted-foreground">Status</span>
            <span><%- include('../partials/status-badge', { status: po.status }) %></span>
          </div>
        </div>
      </div>

      <!-- Item -->
      <div class="card">
        <header>
          <h2>Rincian Barang</h2>
        </header>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-muted-foreground text-left">
                <th class="px-3 py-2 font-medium">Item</th>
                <th class="px-3 py-2 font-medium text-right">Qty</th>
                <th class="px-3 py-2 font-medium text-right">Harga</th>
                <th class="px-3 py-2 font-medium text-right">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach(function (it) { %>
                <tr class="border-t">
                  <td class="px-3 py-2"><%= it.name %></td>
                  <td class="px-3 py-2 text-right"><%= it.quantity %></td>
                  <td class="px-3 py-2 text-right">Rp <%= Number(it.price || 0).toLocaleString('id-ID') %></td>
                  <td class="px-3 py-2 text-right">Rp <%= Number(it.subtotal || 0).toLocaleString('id-ID') %></td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot>
              <tr class="border-t font-bold">
                <td class="px-3 py-2" colspan="3">Total</td>
                <td class="px-3 py-2 text-right">Rp <%= Number(total || 0).toLocaleString('id-ID') %></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
