<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main id="content">
  <%- include('partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto">
      <header class="flex flex-col gap-4 mb-8">
        <div class="flex flex-col gap-2">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl">
            Selamat Datang<%= (typeof user !== 'undefined' && user) ? ', ' + user : '' %> di Facultyware
          </h1>
          <p class="sm:text-lg text-muted-foreground">
            Aplikasi administrasi inventaris dan pengadaan internal fakultas.
          </p>
        </div>
        <div class="flex w-full flex-wrap items-center justify-start gap-2 pt-2">
          <a class="btn" href="/approval/inbox">Buka Inbox Approval (Wadir)</a>
          <% if (typeof can === 'function' && can('manage_request')) { %>
            <a class="btn-outline" href="#">Manage Request (Admin Only)</a>
          <% } %>
          <a class="btn-outline border-red-500 text-red-500 hover:bg-red-50 hover:text-red-600" href="/logout">Logout</a>
        </div>
      </header>

      <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Quick Stats Card -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm">
          <header class="mb-4">
            <h2 class="text-lg font-semibold">Modul Permintaan Pengadaan</h2>
            <p class="text-sm text-muted-foreground">Buat dan kelola permohonan inventaris baru.</p>
          </header>
          <section class="mb-6">
            <p class="text-sm text-muted-foreground mb-4">
              Anda memiliki akses untuk mengajukan permintaan pengadaan, menyimpan draf, melacak status, dan mengunduh berkas laporan dalam format PDF.
            </p>
            <div class="flex items-center gap-2">
              <span class="text-xs bg-primary/10 text-primary px-2.5 py-1 rounded-full font-medium">Akses Aktif</span>
              <span class="text-xs bg-muted text-muted-foreground px-2.5 py-1 rounded-full font-medium">Spatie: manage_procurement</span>
            </div>
          </section>
          <footer class="flex flex-col gap-2">
            <a class="btn w-full justify-center" href="/procurement/create" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              Buat Permintaan Baru
            </a>
            <a class="btn-outline w-full justify-center" href="/procurement" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              Daftar Permintaan
            </a>
          </footer>
        </div>

        <!-- User Information Card -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm">
          <header class="mb-4">
            <h2 class="text-lg font-semibold">Informasi Akun</h2>
            <p class="text-sm text-muted-foreground">Detail login dan profil pegawai Anda.</p>
          </header>
          <section class="space-y-3">
            <div class="flex justify-between border-b pb-2">
              <span class="text-sm text-muted-foreground">Nama Lengkap</span>
              <span class="text-sm font-medium"><%= (typeof user !== 'undefined' && user) ? user : 'User' %></span>
            </div>
            <div class="flex justify-between border-b pb-2">
              <span class="text-sm text-muted-foreground">Status Kepegawaian</span>
              <span class="text-sm text-green-600 font-medium">Aktif</span>
            </div>
          </section>
        </div>
      </section>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
