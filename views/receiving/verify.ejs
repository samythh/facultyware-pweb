<!doctype html>
<html lang="id" class="theme-unand">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (
            stored
              ? stored === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}

        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try {
            localStorage.setItem("themeMode", dark ? "dark" : "light");
          } catch (_) {}
        };
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(
            mode === "dark"
              ? true
              : mode === "light"
                ? false
                : !document.documentElement.classList.contains("dark"),
          );
        });
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · FacultyWare</title>
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <style>
      /* Penyesuaian tata letak halaman penerimaan (warna lewat token tema, sesuai DESIGN-PROMPT). */
      .justify-end { justify-content: flex-end; }
      .theme-fab { position: fixed; top: 1rem; right: 1rem; z-index: 50; }

      /* Pil status: gaya solid berwarna + ikon (referensi label berstatus) */
      .status-pill { display: inline-flex; align-items: center; gap: .4rem; padding: .28rem .8rem; border-radius: 9999px; font-size: .78rem; font-weight: 600; line-height: 1.2; color: oklch(99% 0.01 150); white-space: nowrap; }
      .status-pill svg { width: .95rem; height: .95rem; flex: none; }
      .status-draft { background: oklch(70% 0.15 70); }
      .status-done { background: oklch(55% 0.14 150); }

      /* Header informasi PO (samakan dengan halaman detail) */
      .po-info { display: flex; flex-direction: column; gap: 1.25rem; }
      .po-head { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .75rem; padding-bottom: 1.1rem; border-bottom: 1px solid var(--color-border); }
      .po-eyebrow { display: block; font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; color: var(--color-muted-foreground); margin-bottom: .3rem; }
      .po-number { font-size: 1.75rem; font-weight: 700; letter-spacing: -.01em; color: var(--color-foreground); line-height: 1.1; }
      .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: .85rem; }
      .info-tile { padding: .85rem 1rem; border: 1px solid var(--color-border); border-radius: .65rem; background: var(--color-background); }
      .info-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .05em; color: var(--color-muted-foreground); margin-bottom: .35rem; }
      .info-value { font-size: 1.1rem; font-weight: 600; color: var(--color-foreground); }

      /* Dropzone unggah berkas (kotak besar, isi di tengah) */
      .dropzone { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: .9rem; width: 100%; min-height: 210px; padding: 2rem 1.25rem; border: 1.5px dashed var(--color-border); border-radius: .75rem; background: transparent; cursor: pointer; transition: border-color .18s var(--ease-out, ease), background-color .18s ease; }
      .dropzone:hover, .dropzone.is-dragover { border-color: var(--color-primary); background: color-mix(in oklab, var(--color-primary) 6%, transparent); }
      .dropzone input[type="file"] { display: none; }
      .dropzone-icon { color: var(--color-muted-foreground); }
      .dropzone-title { font-size: .95rem; font-weight: 600; color: var(--color-foreground); }
      .dropzone-or { display: flex; align-items: center; gap: .75rem; width: 180px; color: var(--color-muted-foreground); font-size: .7rem; letter-spacing: .1em; }
      .dropzone-or::before, .dropzone-or::after { content: ""; flex: 1; height: 1px; background: var(--color-border); }
      .dropzone-meta { display: flex; flex-wrap: wrap; justify-content: space-between; gap: .5rem 1.5rem; margin-top: .4rem; font-size: .75rem; color: var(--color-muted-foreground); }
      .dropzone-file { display: none; align-items: center; gap: .5rem; margin-top: .5rem; font-size: .82rem; color: var(--color-foreground); }
      .dropzone-file.is-active { display: flex; }
      .dropzone-file svg { color: var(--color-primary); flex: none; }
    </style>
  </head>
  <body>
    <main id="content">
      <div class="p-4 md:p-6 xl:p-12">
        <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
          <div class="theme-fab">
            <button
              type="button"
              aria-label="Ganti tema terang/gelap"
              title="Ganti tema terang/gelap"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8"
            >
              <span class="hidden dark:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              </span>
              <span class="block dark:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
              </span>
            </button>
          </div>
          <header class="flex flex-col gap-2">
            <a href="/receiving" class="text-sm text-muted-foreground hover:underline">&larr; Kembali ke daftar</a>
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
              Verifikasi Penerimaan
            </h1>
          </header>

          <!-- Info PO -->
          <div class="card">
            <section class="po-info">
              <div class="po-head">
                <div>
                  <span class="po-eyebrow">Nomor Purchase Order</span>
                  <span class="po-number font-mono"><%= po ? po.purchase_number : "-" %></span>
                </div>
                <span class="status-pill <%= po && po.status === 'completed' ? 'status-done' : 'status-draft' %>">
                  <% if (po && po.status === 'completed') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                  <% } else { %>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                  <% } %>
                  <%= po ? po.status_label : "-" %>
                </span>
              </div>
              <div class="info-grid">
                <div class="info-tile">
                  <div class="info-label">Pemasok</div>
                  <div class="info-value"><%= po && po.supplier ? po.supplier : "-" %></div>
                </div>
                <div class="info-tile">
                  <div class="info-label">Tanggal Pembelian</div>
                  <div class="info-value"><%= po ? po.purchase_date : "-" %></div>
                </div>
                <div class="info-tile">
                  <div class="info-label">Jenis Barang</div>
                  <div class="info-value"><%= summary ? summary.itemCount : 0 %> item</div>
                </div>
                <div class="info-tile">
                  <div class="info-label">Total Nilai PO</div>
                  <div class="info-value"><%= summary ? summary.totalValue_label : "Rp 0" %></div>
                </div>
              </div>
            </section>
          </div>

          <!-- Form verifikasi -->
          <form
            class="card"
            action="/receiving/<%= po ? po.id : '0' %>/verify"
            method="post"
            enctype="multipart/form-data"
          >
            <header>
              <h2>Verifikasi Item</h2>
              <p>Isi jumlah yang benar-benar diterima beserta kondisinya.</p>
            </header>
            <section class="grid gap-6">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="text-muted-foreground text-left">
                      <th class="px-3 py-2 font-medium">Nama Barang</th>
                      <th class="px-3 py-2 font-medium">Qty Dipesan</th>
                      <th class="px-3 py-2 font-medium">Qty Diterima</th>
                      <th class="px-3 py-2 font-medium">Kondisi</th>
                      <th class="px-3 py-2 font-medium">Keterangan</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof items !== 'undefined' && items.length > 0) { %>
                      <% items.forEach(function (item) { %>
                        <tr class="border-t">
                          <td class="px-3 py-2"><%= item.name %></td>
                          <td class="px-3 py-2"><%= item.quantity %></td>
                          <td class="px-3 py-2">
                            <input type="number" min="0" class="input w-24"
                              name="received_qty[<%= item.id %>]"
                              value="<%= item.quantity %>" />
                          </td>
                          <td class="px-3 py-2">
                            <select class="select" name="condition[<%= item.id %>]">
                              <option value="baik">Baik</option>
                              <option value="cacat">Cacat</option>
                            </select>
                          </td>
                          <td class="px-3 py-2">
                            <input type="text" class="input w-full"
                              name="notes[<%= item.id %>]" placeholder="Opsional" />
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr class="border-t">
                        <td class="px-3 py-8 text-center text-muted-foreground" colspan="5">
                          Tidak ada item pada purchase order ini.
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Upload bukti -->
              <div class="grid gap-2">
                <label for="bukti">Bukti foto atau surat jalan</label>
                <div class="dropzone" id="dropzone">
                  <input type="file" id="bukti" name="bukti" accept=".jpg,.jpeg,.png,.pdf" />
                  <span class="dropzone-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>
                  </span>
                  <p class="dropzone-title">Seret berkas Anda untuk mulai mengunggah</p>
                  <div class="dropzone-or"><span>ATAU</span></div>
                  <button type="button" class="btn-outline" id="bukti-browse">Pilih Berkas</button>
                </div>
                <div class="dropzone-meta">
                  <span>Format: JPG, JPEG, PNG, atau PDF</span>
                  <span>Ukuran maksimal: 5 MB</span>
                </div>
                <p class="dropzone-file" id="bukti-file">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <span id="bukti-file-name"></span>
                </p>
              </div>
            </section>
            <footer class="flex items-center justify-end gap-2">
              <a href="/receiving" class="btn-outline">Batal</a>
              <button type="submit" class="btn">Simpan Verifikasi</button>
            </footer>
          </form>
        </div>
      </div>
    </main>

    <div id="toaster" class="toaster"></div>

    <script>
      (() => {
        const dz = document.getElementById("dropzone");
        const input = document.getElementById("bukti");
        const browse = document.getElementById("bukti-browse");
        const fileBox = document.getElementById("bukti-file");
        const fileName = document.getElementById("bukti-file-name");
        if (!dz || !input) return;

        // Klik area atau tombol "Pilih Berkas" membuka dialog file.
        dz.addEventListener("click", (e) => {
          if (e.target.closest("#bukti-browse")) return;
          input.click();
        });
        if (browse) {
          browse.addEventListener("click", (e) => {
            e.stopPropagation();
            input.click();
          });
        }

        const showFile = () => {
          if (input.files && input.files.length) {
            fileName.textContent = input.files[0].name;
            fileBox.classList.add("is-active");
          } else {
            fileBox.classList.remove("is-active");
          }
        };

        input.addEventListener("change", showFile);

        ["dragenter", "dragover"].forEach((evt) =>
          dz.addEventListener(evt, (e) => {
            e.preventDefault();
            dz.classList.add("is-dragover");
          })
        );
        ["dragleave", "dragend", "drop"].forEach((evt) =>
          dz.addEventListener(evt, (e) => {
            e.preventDefault();
            dz.classList.remove("is-dragover");
          })
        );
        dz.addEventListener("drop", (e) => {
          if (e.dataTransfer && e.dataTransfer.files.length) {
            input.files = e.dataTransfer.files;
            showFile();
          }
        });
      })();
    </script>
  </body>
</html>
