<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

    <style>
      .justify-end { justify-content: flex-end; }
      .num { text-align: right; font-variant-numeric: tabular-nums; }

      .po-info { display: flex; flex-direction: column; gap: 1.25rem; }
      .po-head { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .75rem; padding-bottom: 1.1rem; border-bottom: 1px solid var(--color-border); }
      .po-eyebrow { display: block; font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; color: var(--color-muted-foreground); margin-bottom: .3rem; }
      .po-number { font-size: 1.75rem; font-weight: 700; letter-spacing: -.01em; color: var(--color-foreground); line-height: 1.1; }
      .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: .85rem; }
      .info-tile { padding: .85rem 1rem; border: 1px solid var(--color-border); border-radius: .65rem; background: var(--color-background); }
      .info-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .05em; color: var(--color-muted-foreground); margin-bottom: .35rem; }
      .info-value { font-size: 1.1rem; font-weight: 600; color: var(--color-foreground); }

      .dropzone { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: .9rem; width: 100%; min-height: 210px; padding: 2rem 1.25rem; border: 1.5px dashed var(--color-border); border-radius: .75rem; background: transparent; cursor: pointer; transition: border-color .18s var(--ease-out, ease), background-color .18s ease; }
      .dropzone:hover, .dropzone.is-dragover { border-color: var(--color-primary); background: color-mix(in oklab, var(--color-primary) 6%, transparent); }
      .dropzone input[type="file"] { display: none; }
      .dropzone-icon { color: var(--color-muted-foreground); }
      .dropzone-title { font-size: .95rem; font-weight: 600; color: var(--color-foreground); }
      .dropzone-or { display: flex; align-items: center; gap: .75rem; width: 180px; color: var(--color-muted-foreground); font-size: .7rem; letter-spacing: .1em; }
      .dropzone-or::before, .dropzone-or::after { content: ""; flex: 1; height: 1px; background: var(--color-border); }
      .dropzone-meta { display: flex; flex-wrap: wrap; justify-content: space-between; gap: .5rem 1.5rem; margin-top: .4rem; font-size: .75rem; color: var(--color-muted-foreground); }
      .dropzone-files { list-style: none; margin: .25rem 0 0; padding: 0; display: flex; flex-direction: column; gap: .4rem; }
      .dropzone-files li { display: flex; align-items: center; gap: .5rem; font-size: .82rem; color: var(--color-foreground); padding: .4rem .6rem; border: 1px solid var(--color-border); border-radius: .5rem; background: var(--color-background); }
      .dropzone-files li.file-row { cursor: pointer; transition: border-color .15s ease, background-color .15s ease; }
      .dropzone-files li.file-row:hover { border-color: var(--color-primary); background: color-mix(in oklab, var(--color-primary) 6%, transparent); }
      .dropzone-files svg { color: var(--color-primary); flex: none; }
      .dropzone-files .file-size { margin-left: auto; font-size: .72rem; color: var(--color-muted-foreground); }
      .dropzone-files .file-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .dropzone-files .file-remove { flex: none; width: 1.4rem; height: 1.4rem; display: inline-flex; align-items: center; justify-content: center; border: 0; border-radius: .35rem; background: transparent; color: var(--color-muted-foreground); font-size: 1.1rem; line-height: 1; cursor: pointer; transition: background-color .15s ease, color .15s ease; }
      .dropzone-files .file-remove:hover { background: var(--color-muted); color: var(--color-foreground); }

      .preview-overlay { position: fixed; inset: 0; z-index: 100; display: none; align-items: center; justify-content: center; padding: 1.5rem; background: oklch(0% 0 0 / .6); }
      .preview-overlay.is-open { display: flex; }
      .preview-box { display: flex; flex-direction: column; width: min(900px, 100%); max-height: 90vh; background: var(--color-background); border: 1px solid var(--color-border); border-radius: .75rem; overflow: hidden; box-shadow: 0 20px 50px oklch(0% 0 0 / .35); }
      .preview-head { display: flex; align-items: center; gap: .75rem; padding: .85rem 1.1rem; border-bottom: 1px solid var(--color-border); }
      .preview-title { font-weight: 600; font-size: .95rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .preview-close { margin-left: auto; flex: none; width: 2rem; height: 2rem; display: inline-flex; align-items: center; justify-content: center; border: 0; border-radius: .5rem; background: transparent; color: var(--color-muted-foreground); font-size: 1.4rem; line-height: 1; cursor: pointer; }
      .preview-close:hover { background: var(--color-muted); color: var(--color-foreground); }
      .preview-body { flex: 1; min-height: 0; display: flex; align-items: center; justify-content: center; background: var(--color-muted); overflow: auto; }
      .preview-body img { max-width: 100%; max-height: 80vh; object-fit: contain; display: block; }
      .preview-body iframe { width: 100%; height: 80vh; border: 0; background: #fff; }
      .preview-fallback { display: flex; flex-direction: column; align-items: center; gap: .75rem; padding: 2.5rem 1.5rem; text-align: center; color: var(--color-muted-foreground); }

      .notice-stack { position: fixed; top: 1rem; left: 50%; transform: translateX(-50%); z-index: 120; display: flex; flex-direction: column; gap: .5rem; width: max-content; max-width: calc(100vw - 2rem); pointer-events: none; }
      .notice { display: flex; align-items: center; gap: .6rem; padding: .7rem 1rem; border-radius: .6rem; font-size: .85rem; font-weight: 500; color: var(--color-foreground); background: var(--color-background); border: 1px solid var(--color-border); box-shadow: 0 10px 30px oklch(0% 0 0 / .18); opacity: 0; transform: translateY(-8px); transition: opacity .2s ease, transform .2s ease; }
      .notice.is-show { opacity: 1; transform: translateY(0); }
      .notice svg { flex: none; color: oklch(70% 0.15 70); }
    </style>

    <div class="p-4 md:p-6 xl:p-12">
        <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
          <header class="flex flex-col gap-2">
            <a href="/receiving" class="text-sm text-muted-foreground hover:underline">&larr; Kembali ke daftar</a>
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
              Verifikasi Penerimaan
            </h1>
          </header>

          <div class="card">
            <section class="po-info">
              <div class="po-head">
                <div>
                  <span class="po-eyebrow">Nomor Purchase Order</span>
                  <span class="po-number font-mono"><%= po ? po.purchase_number : "-" %></span>
                </div>
                <% if (po) { %><%- include('../partials/status-badge', { status: po.status, label: po.status_label }) %><% } %>
              </div>
              <div class="info-grid">
                <div class="info-tile">
                  <div class="info-label">Pemasok</div>
                  <div class="info-value"><%= po && po.supplier ? po.supplier : "-" %></div>
                </div>
                <div class="info-tile">
                  <div class="info-label">Tanggal Pembelian</div>
                  <div class="info-value"><%= po ? po.purchase_date : "-" %></div>
                </div>
                <div class="info-tile">
                  <div class="info-label">Jenis Barang</div>
                  <div class="info-value"><%= summary ? summary.itemCount : 0 %> item</div>
                </div>
                <div class="info-tile">
                  <div class="info-label">Total Nilai PO</div>
                  <div class="info-value"><%= summary ? summary.totalValue_label : "Rp 0" %></div>
                </div>
              </div>
            </section>
          </div>

          <form
            class="card"
            action="/receiving/<%= po ? po.id : '0' %>/verify"
            method="post"
            enctype="multipart/form-data"
          >
            <header>
              <h2>Verifikasi Item</h2>
              <p>Isi jumlah yang diterima <strong>baik</strong>; kolom <strong>cacat</strong> terisi otomatis sebagai sisa (qty dipesan &minus; baik) dan tetap bisa diubah. Bila ada barang yang <strong>tidak diterima/hilang</strong>, turunkan jumlah cacat &mdash; selisihnya muncul di kolom <strong>Kurang/Hilang</strong>. Saat dikonfirmasi, barang fisik (baik + cacat) tercatat masuk ke buku besar; yang cacat dikeluarkan lewat retur ke vendor.</p>
            </header>
            <section class="grid gap-6">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="text-muted-foreground text-left">
                      <th class="px-3 py-2 font-medium">Nama Barang</th>
                      <th class="px-3 py-2 font-medium num">Qty Dipesan</th>
                      <th class="px-3 py-2 font-medium num">Diterima Baik</th>
                      <th class="px-3 py-2 font-medium num">Cacat</th>
                      <th class="px-3 py-2 font-medium num">Kurang/Hilang</th>
                      <th class="px-3 py-2 font-medium">Keterangan</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof items !== 'undefined' && items.length > 0) { %>
                      <% items.forEach(function (item) { %>
                        <tr class="border-t verify-row" data-ordered="<%= item.quantity %>">
                          <td class="px-3 py-2"><%= item.name %></td>
                          <td class="px-3 py-2 num"><%= item.quantity %></td>
                          <td class="px-3 py-2">
                            <input type="number" min="0" max="<%= item.quantity %>" class="input w-24 num good-input"
                              name="good_qty[<%= item.id %>]"
                              value="<%= item.quantity %>" />
                          </td>
                          <td class="px-3 py-2">
                            <input type="number" min="0" max="<%= item.quantity %>" class="input w-24 num defective-input"
                              name="defective_qty[<%= item.id %>]"
                              value="0" />
                          </td>
                          <td class="px-3 py-2 num"><span class="missing-cell">0</span></td>
                          <td class="px-3 py-2">
                            <input type="text" class="input w-full"
                              name="notes[<%= item.id %>]" placeholder="Opsional (mis. alasan cacat / barang hilang)" />
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr class="border-t">
                        <td class="px-3 py-8 text-center text-muted-foreground" colspan="6">
                          Tidak ada item pada purchase order ini.
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <div class="grid gap-2">
                <label for="bukti">Bukti foto atau surat jalan</label>
                <div class="dropzone" id="dropzone">
                  <input type="file" id="bukti" name="bukti" accept=".jpg,.jpeg,.png,.pdf" multiple />
                  <span class="dropzone-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M12 18v-6"/><path d="m9 15 3-3 3 3"/></svg>
                  </span>
                  <p class="dropzone-title">Seret berkas Anda untuk mulai mengunggah</p>
                  <div class="dropzone-or"><span>ATAU</span></div>
                  <button type="button" class="btn-outline" id="bukti-browse">Pilih Berkas</button>
                </div>
                <div class="dropzone-meta">
                  <span>Format: JPG, JPEG, PNG, atau PDF (bisa lebih dari satu)</span>
                  <span>Maks. 5 berkas &middot; 5 MB / berkas</span>
                </div>
                <ul class="dropzone-files" id="bukti-files"></ul>
              </div>
            </section>
            <footer class="flex items-center justify-end gap-2">
              <a href="/receiving" class="btn-outline">Batal</a>
              <button type="submit" class="btn">Simpan Verifikasi</button>
            </footer>
          </form>
        </div>
      </div>
    </main>

    <div class="preview-overlay" id="preview-overlay" role="dialog" aria-modal="true" aria-labelledby="preview-title">
      <div class="preview-box">
        <div class="preview-head">
          <span class="preview-title" id="preview-title">Pratinjau</span>
          <button type="button" class="preview-close" id="preview-close" aria-label="Tutup pratinjau">&times;</button>
        </div>
        <div class="preview-body" id="preview-body"></div>
      </div>
    </div>

    <div class="notice-stack" id="notice-stack" aria-live="polite"></div>

    <script>
      (() => {
        const dz = document.getElementById("dropzone");
        const input = document.getElementById("bukti");
        const browse = document.getElementById("bukti-browse");
        const fileList = document.getElementById("bukti-files");
        if (!dz || !input) return;

        const MAX_FILES = 5;

        const noticeStack = document.getElementById("notice-stack");
        const warnIcon =
          '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>';
        const showNotice = (message) => {
          const el = document.createElement("div");
          el.className = "notice";
          el.innerHTML = warnIcon + "<span></span>";
          el.querySelector("span").textContent = message;
          noticeStack.appendChild(el);
          requestAnimationFrame(() => el.classList.add("is-show"));
          setTimeout(() => {
            el.classList.remove("is-show");
            el.addEventListener("transitionend", () => el.remove(), { once: true });
          }, 3000);
        };

        const fmtSize = (b) =>
          b < 1024 * 1024
            ? (b / 1024).toFixed(0) + " KB"
            : (b / (1024 * 1024)).toFixed(1) + " MB";

        dz.addEventListener("click", (e) => {
          if (e.target.closest("#bukti-browse")) return;
          input.click();
        });
        if (browse) {
          browse.addEventListener("click", (e) => {
            e.stopPropagation();
            input.click();
          });
        }

        const fileIcon =
          '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';

        const store = new DataTransfer();

        const syncInput = () => {
          const dt = new DataTransfer();
          Array.from(store.files).forEach((f) => dt.items.add(f));
          input.files = dt.files;
        };

        const overlay = document.getElementById("preview-overlay");
        const previewTitle = document.getElementById("preview-title");
        const previewBody = document.getElementById("preview-body");
        const previewClose = document.getElementById("preview-close");
        let previewUrl = null;

        const closePreview = () => {
          overlay.classList.remove("is-open");
          previewBody.innerHTML = "";
          if (previewUrl) {
            URL.revokeObjectURL(previewUrl);
            previewUrl = null;
          }
        };

        const openPreview = (file) => {
          if (previewUrl) URL.revokeObjectURL(previewUrl);
          previewUrl = URL.createObjectURL(file);
          previewTitle.textContent = file.name;
          previewBody.innerHTML = "";

          if (file.type.startsWith("image/")) {
            const img = document.createElement("img");
            img.src = previewUrl;
            img.alt = file.name;
            previewBody.appendChild(img);
          } else if (file.type === "application/pdf") {
            const frame = document.createElement("iframe");
            frame.src = previewUrl;
            frame.title = file.name;
            previewBody.appendChild(frame);
          } else {
            const box = document.createElement("div");
            box.className = "preview-fallback";
            box.innerHTML =
              '<p>Pratinjau tidak tersedia untuk tipe berkas ini.</p>';
            const a = document.createElement("a");
            a.className = "btn-outline";
            a.href = previewUrl;
            a.download = file.name;
            a.textContent = "Unduh berkas";
            box.appendChild(a);
            previewBody.appendChild(box);
          }
          overlay.classList.add("is-open");
        };

        previewClose.addEventListener("click", closePreview);
        overlay.addEventListener("click", (e) => {
          if (e.target === overlay) closePreview();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && overlay.classList.contains("is-open")) {
            closePreview();
          }
        });

        const render = () => {
          fileList.innerHTML = "";
          Array.from(store.files).forEach((f, idx) => {
            const li = document.createElement("li");
            li.className = "file-row";
            li.title = "Klik untuk pratinjau";
            li.addEventListener("click", () => openPreview(f));

            const icon = document.createElement("span");
            icon.innerHTML = fileIcon;
            li.appendChild(icon.firstChild);

            const name = document.createElement("span");
            name.className = "file-name";
            name.textContent = f.name;
            li.appendChild(name);

            const size = document.createElement("span");
            size.className = "file-size";
            size.textContent = fmtSize(f.size);
            li.appendChild(size);

            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "file-remove";
            btn.setAttribute("aria-label", "Hapus berkas");
            btn.textContent = "×";
            btn.addEventListener("click", (e) => {
              e.stopPropagation(); // jangan picu pratinjau saat hapus
              store.items.remove(idx);
              syncInput();
              render();
            });
            li.appendChild(btn);

            fileList.appendChild(li);
          });
        };

        const addFiles = (fileListLike) => {
          const existing = new Set(
            Array.from(store.files).map((f) => f.name + ":" + f.size)
          );
          let added = 0;
          for (const f of Array.from(fileListLike)) {
            if (store.files.length >= MAX_FILES) {
              showNotice("Maksimal " + MAX_FILES + " berkas.");
              break;
            }
            const key = f.name + ":" + f.size;
            if (existing.has(key)) continue; 
            store.items.add(f);
            existing.add(key);
            added++;
          }
          if (added) {
            syncInput();
            render();
          }
        };

        input.addEventListener("change", () => {
          addFiles(input.files);
          input.value = "";
          syncInput();
        });

        ["dragenter", "dragover"].forEach((evt) =>
          dz.addEventListener(evt, (e) => {
            e.preventDefault();
            dz.classList.add("is-dragover");
          })
        );
        ["dragleave", "dragend", "drop"].forEach((evt) =>
          dz.addEventListener(evt, (e) => {
            e.preventDefault();
            dz.classList.remove("is-dragover");
          })
        );
        dz.addEventListener("drop", (e) => {
          if (e.dataTransfer && e.dataTransfer.files.length) {
            addFiles(e.dataTransfer.files);
          }
        });
      })();
    </script>

    <script>
      (() => {
        const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));
        document.querySelectorAll(".verify-row").forEach((row) => {
          const ordered = Number(row.dataset.ordered) || 0;
          const good = row.querySelector(".good-input");
          const def = row.querySelector(".defective-input");
          const missing = row.querySelector(".missing-cell");
          if (!good || !def || !missing) return;

          const recalc = () => {
            const g = clamp(parseInt(good.value, 10) || 0, 0, ordered);
            good.value = g;
            const d = clamp(parseInt(def.value, 10) || 0, 0, ordered - g);
            def.value = d;
            const m = ordered - g - d;
            missing.textContent = m;
            missing.style.color = m > 0 ? "#dc2626" : "var(--color-muted-foreground)";
            missing.style.fontWeight = m > 0 ? "600" : "400";
          };

          good.addEventListener("input", () => {
            const g = clamp(parseInt(good.value, 10) || 0, 0, ordered);
            def.value = ordered - g; 
            recalc();
          });
          def.addEventListener("input", recalc);
          recalc();
        });
      })();
    </script>

<%- include('../partials/footer') %>
