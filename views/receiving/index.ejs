<!doctype html>
<html lang="id" class="theme-unand">
  <head>
    <script>
      (() => {
        try {
          const stored = localStorage.getItem("themeMode");
          if (
            stored
              ? stored === "dark"
              : matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}

        const apply = (dark) => {
          document.documentElement.classList.toggle("dark", dark);
          try {
            localStorage.setItem("themeMode", dark ? "dark" : "light");
          } catch (_) {}
        };
        document.addEventListener("basecoat:theme", (event) => {
          const mode = event.detail?.mode;
          apply(
            mode === "dark"
              ? true
              : mode === "light"
                ? false
                : !document.documentElement.classList.contains("dark"),
          );
        });
      })();
    </script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · FacultyWare</title>
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    <link rel="stylesheet" href="/assets/styles.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4"></script>
    <style>
      /* Gaya khusus halaman daftar penerimaan (warna memakai token tema). */
      .justify-end { justify-content: flex-end; }
      .theme-fab { position: fixed; top: 1rem; right: 1rem; z-index: 50; }

      /* Pil status: gaya solid berwarna + ikon (referensi label berstatus) */
      .status-pill { display: inline-flex; align-items: center; gap: .4rem; padding: .28rem .8rem; border-radius: 9999px; font-size: .78rem; font-weight: 600; line-height: 1.2; color: oklch(99% 0.01 150); white-space: nowrap; }
      .status-pill svg { width: .95rem; height: .95rem; flex: none; }
      .status-draft { background: oklch(70% 0.15 70); }
      .status-done { background: oklch(55% 0.14 150); }

      /* Indikator pencarian (muncul hanya saat request HTMX berjalan) */
      .htmx-indicator { display: none; }
      .htmx-request.htmx-indicator { display: inline; }
    </style>
  </head>
  <body>
    <main id="content">
      <div class="p-4 md:p-6 xl:p-12">
        <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
          <div class="theme-fab">
            <button
              type="button"
              aria-label="Ganti tema terang/gelap"
              title="Ganti tema terang/gelap"
              onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
              class="btn-icon-outline size-8"
            >
              <span class="hidden dark:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
              </span>
              <span class="block dark:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
              </span>
            </button>
          </div>
          <header class="flex flex-col gap-2">
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
              Penerimaan Barang
            </h1>
            <p class="text-muted-foreground">
              Verifikasi, konfirmasi, dan kelola penerimaan barang dari vendor.
            </p>
          </header>

          <div class="card">
            <section class="grid gap-4">
              <!-- Search (live, via HTMX) -->
              <form
                class="flex items-center justify-end gap-2"
                action="/receiving"
                method="get"
                hx-get="/receiving"
                hx-target="#receiving-results"
                hx-select="#receiving-results"
                hx-swap="outerHTML"
                hx-push-url="true"
              >
                <input
                  type="search"
                  name="q"
                  class="input w-72 max-w-full"
                  placeholder="Cari nomor PO atau pemasok"
                  value="<%= typeof search !== 'undefined' ? search : '' %>"
                  autocomplete="off"
                  hx-get="/receiving"
                  hx-trigger="keyup changed delay:300ms, search"
                  hx-target="#receiving-results"
                  hx-select="#receiving-results"
                  hx-swap="outerHTML"
                  hx-push-url="true"
                  hx-indicator="#search-indicator"
                />
                <span id="search-indicator" class="htmx-indicator text-sm text-muted-foreground">Mencari…</span>
                <button type="submit" class="btn-outline">Cari</button>
              </form>

              <div id="receiving-results" class="grid gap-4">
              <!-- Tabel penerimaan -->
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="text-muted-foreground text-left">
                      <th class="px-3 py-2 font-medium">No PO</th>
                      <th class="px-3 py-2 font-medium">Supplier</th>
                      <th class="px-3 py-2 font-medium">Tanggal</th>
                      <th class="px-3 py-2 font-medium">Status</th>
                      <th class="px-3 py-2 font-medium text-right">Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (typeof rows !== 'undefined' && rows.length > 0) { %>
                      <% rows.forEach(function (po) { %>
                        <tr class="border-t">
                          <td class="px-3 py-2 font-mono"><%= po.purchase_number %></td>
                          <td class="px-3 py-2"><%= po.supplier %></td>
                          <td class="px-3 py-2"><%= po.purchase_date %></td>
                          <td class="px-3 py-2">
                            <span class="status-pill <%= po.status === 'completed' ? 'status-done' : 'status-draft' %>">
                              <% if (po.status === 'completed') { %>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                              <% } else { %>
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                              <% } %>
                              <%= po.status_label %>
                            </span>
                          </td>
                          <td class="px-3 py-2">
                            <div class="flex items-center justify-end gap-2">
                              <a class="btn-sm" href="/receiving/<%= po.id %>/verify">Verifikasi</a>
                              <a class="btn-sm-outline" href="/receiving/<%= po.id %>/detail">Detail</a>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr class="border-t">
                        <td class="px-3 py-8 text-center text-muted-foreground" colspan="5">
                          Tidak ada data penerimaan barang untuk ditampilkan.
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Pagination skeleton -->
              <nav class="flex items-center justify-between" aria-label="Pagination">
                <span class="text-sm text-muted-foreground">
                  Halaman <%= typeof page !== 'undefined' ? page : 1 %>
                  dari <%= typeof totalPages !== 'undefined' ? totalPages : 1 %>
                </span>
                <div class="flex items-center gap-2">
                  <button type="button" class="btn-sm-outline" disabled>Sebelumnya</button>
                  <button type="button" class="btn-sm-outline" disabled>Berikutnya</button>
                </div>
              </nav>
              </div>
            </section>
          </div>
        </div>
      </div>
    </main>

    <div id="toaster" class="toaster"></div>
  </body>
</html>
