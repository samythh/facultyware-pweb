<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

    <style>
      /* Indikator pencarian (muncul hanya saat request HTMX berjalan) */
      .htmx-indicator { display: none; }
      .htmx-request.htmx-indicator { display: inline; }
    </style>

    <div class="p-4 md:p-6 xl:p-12">
        <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
          <!-- Top Title -->
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
              <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Penerimaan Barang</h1>
              <p class="text-sm text-muted-foreground">Verifikasi, konfirmasi, dan kelola penerimaan barang dari vendor.</p>
            </div>
          </div>

          <!-- Search & Sort Card -->
          <div class="card p-4 bg-card rounded-xl border shadow-sm">
            <div class="flex flex-wrap items-center justify-between gap-4">
              <form
                class="flex gap-2"
                style="flex:1 1 260px;"
                action="/receiving"
                method="get"
                hx-get="/receiving"
                hx-target="#receiving-results"
                hx-select="#receiving-results"
                hx-swap="outerHTML"
                hx-push-url="true"
              >
                <div class="relative flex-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-muted-foreground">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                  </svg>
                  <input
                    type="search"
                    name="q"
                    class="input w-full"
                    style="padding-left: 2.5rem !important;"
                    placeholder="Cari berdasarkan nomor PO atau pemasok..."
                    value="<%= typeof search !== 'undefined' ? search : '' %>"
                    autocomplete="off"
                    hx-get="/receiving"
                    hx-trigger="keyup changed delay:300ms, search"
                    hx-target="#receiving-results"
                    hx-select="#receiving-results"
                    hx-swap="outerHTML"
                    hx-push-url="true"
                    hx-include="closest form"
                    hx-indicator="#search-indicator"
                  />
                </div>
                <input type="hidden" name="sort" value="<%= typeof sort !== 'undefined' ? sort : '' %>" />
                <span id="search-indicator" class="htmx-indicator text-sm text-muted-foreground self-center">Mencari…</span>
                <button type="submit" class="btn-outline">Cari</button>
              </form>
              <%- include('../partials/sort-control', { action: '/receiving', current: (typeof sort !== 'undefined' ? sort : ''), opts: (typeof sortOptions !== 'undefined' ? sortOptions : []), keep: { q: (typeof search !== 'undefined' ? search : '') } }) %>
            </div>
          </div>

          <!-- Table Card -->
          <div id="receiving-results" class="card card--table bg-card rounded-xl border shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse text-sm">
                <thead>
                  <tr class="bg-muted/50 border-b">
                    <th class="p-4 font-semibold text-muted-foreground w-[60px]">No</th>
                    <th class="p-4 font-semibold text-muted-foreground w-[180px]">No PO</th>
                    <th class="p-4 font-semibold text-muted-foreground">Supplier</th>
                    <th class="p-4 font-semibold text-muted-foreground w-[150px]">Tanggal</th>
                    <th class="p-4 font-semibold text-muted-foreground w-[150px]">Status</th>
                    <th class="p-4 font-semibold text-muted-foreground w-[180px] text-right">Aksi</th>
                  </tr>
                </thead>
                <tbody class="divide-y">
                  <% if (typeof rows !== 'undefined' && rows.length > 0) { %>
                    <% const _start = ((typeof page !== 'undefined' ? page : 1) - 1) * 10; %>
                    <% rows.forEach(function (po, idx) { %>
                      <tr class="hover:bg-muted/30 transition-colors">
                        <td class="p-4 font-medium text-muted-foreground"><%= _start + idx + 1 %></td>
                        <td class="p-4 font-mono font-semibold text-primary"><%= po.purchase_number %></td>
                        <td class="p-4 font-medium"><%= po.supplier %></td>
                        <td class="p-4 text-muted-foreground"><%= fmtDate(po.purchase_date) %></td>
                        <td class="p-4"><%- include('../partials/status-badge', { status: po.status, label: po.status_label }) %></td>
                        <td class="p-4 text-right">
                          <div class="flex items-center justify-end gap-2">
                            <% if (po.status !== 'completed') { %>
                              <a class="btn-success" href="/receiving/<%= po.id %>/verify">Verifikasi</a>
                            <% } %>
                            <a class="btn-action-view" href="/receiving/<%= po.id %>/detail">Detail</a>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td class="p-8 text-center text-muted-foreground" colspan="6">
                        Tidak ada data penerimaan barang untuk ditampilkan.
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>

            <!-- Pagination -->
            <% const _pg = (typeof page !== 'undefined' ? page : 1); const _tp = (typeof totalPages !== 'undefined' ? totalPages : 1); const _q = (typeof search !== 'undefined' ? search : ''); %>
            <div class="p-4 border-t flex items-center justify-between gap-4" aria-label="Pagination">
              <span class="text-xs text-muted-foreground">Halaman <%= _pg %> dari <%= _tp %></span>
              <div class="flex gap-1" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
                <% if (_pg > 1) { %>
                  <a href="/receiving?page=<%= _pg - 1 %>&q=<%= _q %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" class="btn-xs-outline">Sebelumnya</a>
                <% } else { %>
                  <button type="button" class="btn-xs-outline select-none" disabled>Sebelumnya</button>
                <% } %>
                <% for (let i = 1; i <= _tp; i++) { %>
                  <% if (i === _pg) { %>
                    <button type="button" class="btn-xs font-semibold select-none"><%= i %></button>
                  <% } else { %>
                    <a href="/receiving?page=<%= i %>&q=<%= _q %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" class="btn-xs-outline"><%= i %></a>
                  <% } %>
                <% } %>
                <% if (_pg < _tp) { %>
                  <a href="/receiving?page=<%= _pg + 1 %>&q=<%= _q %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" class="btn-xs-outline">Berikutnya</a>
                <% } else { %>
                  <button type="button" class="btn-xs-outline select-none" disabled>Berikutnya</button>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

<%- include('../partials/footer') %>
