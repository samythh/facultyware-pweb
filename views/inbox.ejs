<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main id="content">
  <%- include('partials/navbar') %>

  <style>
    /* Badge status & warna angka statistik (mandiri, tidak bergantung utilitas warna). */
    .badge { display: inline-flex; align-items: center; padding: .15rem .6rem; border-radius: 9999px; font-size: .72rem; font-weight: 600; line-height: 1.3; }
    .badge-pending { background: #fef9c3; color: #854d0e; }
    .badge-approved { background: #dcfce7; color: #166534; }
    .badge-rejected { background: #fee2e2; color: #991b1b; }
    .stat-pending { color: #ca8a04; }
    .stat-approved { color: #16a34a; }
    .stat-rejected { color: #dc2626; }
  </style>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="flex flex-col gap-2">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl"><%= title %></h1>
          <p class="text-muted-foreground">
            <% if (tab === 'history') { %>
              Riwayat keputusan persetujuan pengadaan barang.
            <% } else { %>
              Tinjau dan setujui permintaan pengadaan barang fakultas.
            <% } %>
          </p>
        </div>
        <% if (tab === 'history') { %>
          <div class="flex items-center gap-2">
            <a href="/approval/rekap/export?format=pdf" class="btn-outline">Export PDF</a>
            <a href="/approval/rekap/export?format=excel" class="btn-outline">Export Excel</a>
          </div>
        <% } %>
      </header>

      <div class="card">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-muted-foreground text-left">
                <th class="px-3 py-2 font-medium">No</th>
                <th class="px-3 py-2 font-medium">Tanggal</th>
                <th class="px-3 py-2 font-medium">Pemohon</th>
                <th class="px-3 py-2 font-medium">Judul</th>
                <th class="px-3 py-2 font-medium">Status</th>
                <th class="px-3 py-2 font-medium text-right">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% if (procurements && procurements.length > 0) { %>
                <% procurements.forEach(function (proc) { %>
                  <tr class="border-t hover:bg-muted cursor-pointer" onclick="window.location.href='/approval/<%= proc.id %>'">
                    <td class="px-3 py-2 font-mono">#<%= proc.request_number %></td>
                    <td class="px-3 py-2"><%= new Date(proc.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                    <td class="px-3 py-2 font-medium"><%= proc.pemohon_name || 'Unit/Staf' %></td>
                    <td class="px-3 py-2"><%= proc.title %></td>
                    <td class="px-3 py-2">
                      <% if (proc.status === 'submitted' || proc.status === 'draft') { %>
                        <span class="badge badge-pending">Pending</span>
                      <% } else if (proc.status === 'approved') { %>
                        <span class="badge badge-approved">Disetujui</span>
                      <% } else if (proc.status === 'rejected') { %>
                        <span class="badge badge-rejected">Ditolak</span>
                      <% } %>
                    </td>
                    <td class="px-3 py-2 text-right">
                      <a href="/approval/<%= proc.id %>" class="btn-sm-outline" onclick="event.stopPropagation()">Detail</a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr class="border-t">
                  <td colspan="6" class="px-3 py-8 text-center text-muted-foreground">
                    Belum ada permintaan pengadaan yang masuk.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div class="flex items-center justify-between border-t px-3 py-3 text-sm text-muted-foreground">
          <span>Menampilkan <%= procurements ? procurements.length : 0 %> permintaan</span>
        </div>
      </div>

      <!-- Statistik -->
      <section class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="card p-6 text-center">
          <h2 class="text-sm font-medium uppercase text-muted-foreground">Total Pending</h2>
          <p class="text-3xl font-bold stat-pending mt-2"><%= typeof totalPending !== 'undefined' ? totalPending : 0 %></p>
        </div>
        <div class="card p-6 text-center">
          <h2 class="text-sm font-medium uppercase text-muted-foreground">Total Disetujui</h2>
          <p class="text-3xl font-bold stat-approved mt-2"><%= typeof totalApproved !== 'undefined' ? totalApproved : 0 %></p>
        </div>
        <div class="card p-6 text-center">
          <h2 class="text-sm font-medium uppercase text-muted-foreground">Total Ditolak</h2>
          <p class="text-3xl font-bold stat-rejected mt-2"><%= typeof totalRejected !== 'undefined' ? totalRejected : 0 %></p>
        </div>
      </section>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
