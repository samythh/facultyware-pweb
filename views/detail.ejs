<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main id="content">
  <%- include('partials/navbar') %>

  <style>
    /* Badge status (mandiri, tidak bergantung utilitas warna). */
    .badge { display: inline-flex; align-items: center; padding: .15rem .6rem; border-radius: 9999px; font-size: .72rem; font-weight: 600; line-height: 1.3; }
    .badge-pending { background: #fef9c3; color: #854d0e; }
    .badge-approved { background: #dcfce7; color: #166534; }
    .badge-rejected { background: #fee2e2; color: #991b1b; }
  </style>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      <header class="flex flex-col gap-2">
        <a href="/approval" class="text-sm text-muted-foreground hover:underline">&larr; Kembali ke Inbox</a>
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">
          Detail Permintaan #<%= procurement.request_number %>
        </h1>
      </header>

      <!-- Info Pemohon -->
      <div class="card">
        <section class="grid gap-4">
          <div class="flex flex-col gap-1">
            <span class="text-xs uppercase tracking-wide text-muted-foreground">Pemohon</span>
            <span class="text-lg font-semibold"><%= procurement.pemohon_name || 'Staf / Admin' %></span>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-wide text-muted-foreground">Tanggal</span>
              <span class="font-medium">
                <%= new Date(procurement.created_at).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </span>
            </div>
            <div class="flex flex-col gap-1">
              <span class="text-xs uppercase tracking-wide text-muted-foreground">Status</span>
              <span>
                <% if (procurement.status === 'pending' || procurement.status === 'submitted' || procurement.status === 'draft') { %>
                  <span class="badge badge-pending">Pending</span>
                <% } else if (procurement.status === 'approved') { %>
                  <span class="badge badge-approved">Disetujui</span>
                <% } else if (procurement.status === 'rejected') { %>
                  <span class="badge badge-rejected">Ditolak</span>
                <% } else { %>
                  <span class="badge badge-pending"><%= procurement.status %></span>
                <% } %>
              </span>
            </div>
          </div>
        </section>
      </div>

      <!-- Barang Diajukan -->
      <div class="card">
        <header>
          <h2>Barang Diajukan</h2>
          <p>Daftar barang pada permintaan pengadaan ini.</p>
        </header>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-muted-foreground text-left">
                <th class="px-3 py-2 font-medium">Deskripsi</th>
                <th class="px-3 py-2 font-medium text-right">Qty</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof items !== 'undefined' && items.length > 0) { %>
                <% items.forEach(function (item) { %>
                  <tr class="border-t">
                    <td class="px-3 py-2"><%= item.item_name %></td>
                    <td class="px-3 py-2 text-right font-mono"><%= item.quantity %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr class="border-t">
                  <td colspan="2" class="px-3 py-8 text-center text-muted-foreground">Tidak ada barang pada permintaan ini.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Catatan Penolakan -->
      <% if (procurement.status === 'rejected' && procurement.notes) { %>
      <div class="card border-red-500/50 bg-red-50/50">
        <header>
          <h2 class="text-red-700">Catatan Penolakan</h2>
        </header>
        <p class="text-sm leading-relaxed text-red-900"><%= procurement.notes %></p>
      </div>
      <% } %>

      <!-- Aksi (hanya saat status pending / menunggu) -->
      <% if (procurement.status === 'pending') { %>
        <div class="flex flex-wrap items-center gap-2">
          <button type="button" class="btn"
            onclick="document.getElementById('dialog-approve').showModal()">
            Setujui Permintaan
          </button>
          <button type="button" class="btn-outline text-destructive hover:bg-destructive/10"
            onclick="document.getElementById('dialog-reject').showModal()">
            Tolak Permintaan
          </button>
        </div>
      <% } %>
    </div>
  </div>
</main>

<!-- Modal: Konfirmasi Persetujuan -->
<dialog id="dialog-approve" class="dialog" aria-labelledby="dialog-approve-title">
  <article>
    <header>
      <h2 id="dialog-approve-title">Konfirmasi Persetujuan</h2>
      <p>Yakin menyetujui permintaan pengadaan ini?</p>
    </header>
    <form method="post" action="/approval/<%= procurement.id %>/approve">
      <footer class="flex items-center justify-end gap-2">
        <button type="button" class="btn-outline"
          onclick="document.getElementById('dialog-approve').close()">Batal</button>
        <button type="submit" class="btn">Ya, Setujui</button>
      </footer>
    </form>
  </article>
</dialog>

<!-- Modal: Alasan Penolakan -->
<dialog id="dialog-reject" class="dialog" aria-labelledby="dialog-reject-title">
  <article>
    <header>
      <h2 id="dialog-reject-title">Alasan Penolakan</h2>
      <p>Tuliskan alasan penolakan permintaan ini.</p>
    </header>
    <form method="post" action="/approval/<%= procurement.id %>/reject" class="grid gap-4">
      <div class="grid gap-2">
        <label for="rejectionNote">Catatan Penolakan</label>
        <textarea id="rejectionNote" name="notes" class="input" rows="4" required
          placeholder="Masukkan alasan penolakan secara mendetail..."></textarea>
      </div>
      <footer class="flex items-center justify-end gap-2">
        <button type="button" class="btn-outline"
          onclick="document.getElementById('dialog-reject').close()">Batal</button>
        <button type="submit" class="btn">Kirim Penolakan</button>
      </footer>
    </form>
  </article>
</dialog>

<%- include('partials/footer') %>
