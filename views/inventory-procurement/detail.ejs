<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto">

      <!-- Breadcrumb & Back Link -->
      <div class="mb-6 flex flex-col gap-2">
        <div class="flex items-center gap-1.5 text-xs text-muted-foreground" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <a href="/procurement" class="hover:text-foreground">Permintaan Barang</a>
          <span>/</span>
          <span class="text-foreground"><%= procurement.request_number %></span>
        </div>
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <div>
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Detail Permintaan Barang</h1>
            <p class="text-sm text-muted-foreground">Detail dan perkembangan permohonan barang.</p>
          </div>
          <div class="flex flex-wrap gap-2 sm:justify-end">
            <% if (procurement.status === 'pending') { %>
              <button type="button" onclick="window.openEditModal()" class="btn shrink-0">Edit</button>
              <button type="button" onclick="window.openDeleteModal()" class="btn-outline shrink-0 text-destructive hover:bg-destructive/10">Hapus</button>
            <% } %>
            <a href="/procurement/<%= procurement.id %>/export" class="btn-outline inline-flex items-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
              Ekspor PDF
            </a>
          </div>
        </div>
      </div>

  <style>
    /* Premium Responsive Stepper */
    .stepper-container {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      width: 100%;
    }
    @media (min-width: 768px) {
      .stepper-container {
        flex-direction: row;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
      }
    }

    .stepper-step {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;
      position: relative;
      flex: 1;
    }
    @media (min-width: 768px) {
      .stepper-step {
        flex-direction: column;
        text-align: center;
        gap: 0.5rem;
      }
    }

    /* Step Badge styles */
    .step-badge {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 9999px;
      font-size: 0.875rem;
      font-weight: 700;
      z-index: 2;
      position: relative;
      transition: all 0.25s ease;
      background: var(--color-background, #ffffff);
    }

    .step-badge-pending {
      border: 2px solid var(--color-border);
      color: var(--color-muted-foreground);
    }

    .step-badge-active {
      border: 2px solid var(--color-primary);
      background: var(--color-primary);
      color: #ffffff;
      box-shadow: 0 0 0 4px color-mix(in oklab, var(--color-primary) 15%, transparent);
    }

    .step-badge-done {
      border: 2px solid #10b981;
      background: #10b981;
      color: #ffffff;
    }

    .step-badge-rejected {
      border: 2px solid #ef4444;
      background: #ef4444;
      color: #ffffff;
      box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15);
    }

    /* Connectors */
    @media (min-width: 768px) {
      .stepper-step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 1.125rem;
        left: calc(50% + 1.25rem);
        width: calc(100% - 2.5rem);
        height: 2px;
        background: var(--color-border);
        z-index: 1;
        transition: background-color 0.25s ease;
      }
      .stepper-step.is-done:not(:last-child)::after {
        background: #10b981;
      }
    }
    @media (max-width: 767px) {
      .stepper-step:not(:last-child)::after {
        content: '';
        position: absolute;
        left: 1.125rem;
        top: 2.25rem;
        width: 2px;
        height: calc(100% + 1.5rem);
        background: var(--color-border);
        z-index: 1;
        transition: background-color 0.25s ease;
      }
      .stepper-step.is-done:not(:last-child)::after {
        background: #10b981;
      }
    }

    .step-content {
      display: flex;
      flex-direction: column;
      text-align: left;
    }
    @media (min-width: 768px) {
      .step-content {
        text-align: center;
        align-items: center;
      }
    }

    .step-title {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-muted-foreground);
    }
    .stepper-step.is-active .step-title {
      color: var(--color-primary);
      font-weight: 700;
    }
    .stepper-step.is-done .step-title {
      color: var(--color-foreground);
    }
    .stepper-step.is-rejected .step-title {
      color: #ef4444;
      font-weight: 700;
    }

    .step-desc {
      font-size: 0.68rem;
      color: var(--color-muted-foreground);
      margin-top: 0.125rem;
    }
  </style>

  <%
    let currentStage = 1;
    let hasPo = (typeof po !== 'undefined' && po !== null);
    let poStatus = hasPo ? po.status : null;
    
    if (procurement.status === 'pending') {
      currentStage = 1;
    } else if (procurement.status === 'rejected') {
      currentStage = 2; // Stays at 2 with error
    } else if (procurement.status === 'approved') {
      if (!procurement.inventory_procurement_id) {
        currentStage = 3; // Passed Stage 2, waiting for consolidation
      } else {
        if (!hasPo) {
          currentStage = 4; // Consolidated, waiting for PO creation
        } else {
          if (poStatus === 'pending') {
            currentStage = 5; // PO created, waiting for PO approval
          } else if (poStatus === 'approved') {
            currentStage = 6; // PO approved, waiting for receipt of goods
          } else if (poStatus === 'rejected') {
            currentStage = 5; // PO rejected, stays at 5 with error
          } else if (poStatus === 'completed') {
            currentStage = 6; // Goods received, completed
          }
        }
      }
    } else if (procurement.status === 'fulfilled') {
      currentStage = 6;
    }

    const steps = [
      {
        num: 1,
        title: "Diajukan",
        desc: "Menunggu Persetujuan",
        isDone: currentStage > 1,
        isActive: currentStage === 1,
        isRejected: false
      },
      {
        num: 2,
        title: procurement.status === 'rejected' ? "Ditolak Wakil Dekan" : (currentStage > 2 ? "Disetujui Wakil Dekan" : "Persetujuan Permintaan"),
        desc: procurement.status === 'rejected' ? "Permintaan Ditolak" : (currentStage > 2 ? "Permintaan Disetujui" : "Menunggu Keputusan"),
        isDone: currentStage > 2,
        isActive: currentStage === 2 && procurement.status !== 'rejected',
        isRejected: procurement.status === 'rejected'
      },
      {
        num: 3,
        title: "Masuk Pengadaan",
        desc: currentStage > 3 ? "Digabung ke Paket" : "Proses Penggabungan",
        isDone: currentStage > 3,
        isActive: currentStage === 3,
        isRejected: false
      },
      {
        num: 4,
        title: "PO Dibuat",
        desc: currentStage > 4 ? "Pesanan Dibuat" : "Menunggu Persetujuan Belanja",
        isDone: currentStage > 4,
        isActive: currentStage === 4,
        isRejected: false
      },
      {
        num: 5,
        title: hasPo && poStatus === 'rejected' ? "Belanja Ditolak" : (currentStage > 5 ? "Belanja Disetujui" : "Persetujuan Belanja"),
        desc: hasPo && poStatus === 'rejected' ? "Ditolak Wakil Dekan" : (currentStage > 5 ? "Siap Kirim & Terima" : "Menunggu Keputusan"),
        isDone: currentStage > 5,
        isActive: currentStage === 5 && poStatus !== 'rejected',
        isRejected: hasPo && poStatus === 'rejected'
      },
      {
        num: 6,
        title: "Barang Diterima",
        desc: currentStage === 6 ? "Selesai / Terpenuhi" : "Menunggu Penerimaan",
        isDone: currentStage === 6 && (procurement.status === 'fulfilled' || poStatus === 'completed'),
        isActive: currentStage === 6 && (procurement.status !== 'fulfilled' && poStatus !== 'completed'),
        isRejected: false
      }
    ];
  %>

  <!-- Tracking Status Timeline Stepper -->
  <div class="card p-6 bg-card rounded-xl border shadow-sm mb-6">
    <h3 class="text-sm font-semibold text-center text-muted-foreground uppercase tracking-wider mb-6">Status Perkembangan Pengajuan</h3>
    
    <div class="stepper-container my-4">
      <% steps.forEach(step => { %>
        <div class="stepper-step <%= step.isDone ? 'is-done' : '' %> <%= step.isActive ? 'is-active' : '' %> <%= step.isRejected ? 'is-rejected' : '' %>">
          <div class="step-badge <%= step.isDone ? 'step-badge-done' : (step.isRejected ? 'step-badge-rejected' : (step.isActive ? 'step-badge-active' : 'step-badge-pending')) %>">
            <% if (step.isDone) { %>
              ✓
            <% } else if (step.isRejected) { %>
              ✗
            <% } else { %>
              <%= step.num %>
            <% } %>
          </div>
          <div class="step-content">
            <span class="step-title"><%= step.title %></span>
            <span class="step-desc"><%= step.desc %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Info Pengajuan -->
  <div class="card mb-6">
    <section class="po-info">
      <div class="po-head">
        <div>
          <span class="po-eyebrow">Nomor Permintaan</span>
          <span class="po-number font-mono text-primary"><%= procurement.request_number %></span>
        </div>
        <%- include('../partials/status-badge', { status: procurement.status }) %>
      </div>
      <div class="info-grid">
        <div class="info-tile">
          <div class="info-label">Deskripsi Utama</div>
          <div class="info-value"><%= procurement.title %></div>
        </div>
        <div class="info-tile">
          <div class="info-label">Tanggal Pengajuan</div>
          <div class="info-value"><%= fmtDate(procurement.request_date) %></div>
        </div>
        <div class="info-tile">
          <div class="info-label">Pemohon</div>
          <div class="info-value"><%= procurement.pemohon_name || 'Staf / Admin' %></div>
        </div>
        <div class="info-tile">
          <div class="info-label">Jumlah Jenis Barang</div>
          <div class="info-value"><%= items.length %> item</div>
        </div>
      </div>
    </section>
  </div>

  <!-- Alasan Penolakan (muncul bila permintaan ditolak) -->
  <% if (procurement.status === 'rejected') { %>
  <div class="card p-6 bg-card rounded-xl border border-red-500/40 bg-red-50/40 mb-6 space-y-1">
    <h3 class="text-base font-semibold text-red-700">Alasan Penolakan</h3>
    <p class="text-sm text-red-900"><%= rejectionNote ? rejectionNote : 'Tidak ada catatan yang diberikan.' %></p>
  </div>
  <% } %>

  <!-- Daftar Barang Permintaan -->
  <div class="card p-6 bg-card rounded-xl border shadow-sm mb-6 space-y-4">
    <h3 class="text-base font-semibold">Daftar Barang Permintaan</h3>
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b text-muted-foreground font-semibold">
            <th class="pb-3 w-[60px]">No</th>
            <th class="pb-3">Nama Barang</th>
            <th class="pb-3 text-right w-[150px]">Jumlah (Quantity)</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% items.forEach((item, index) => { %>
            <tr class="hover:bg-muted/10">
              <td class="py-3 font-medium text-muted-foreground"><%= index + 1 %></td>
              <td class="py-3"><%= item.item_name %></td>
              <td class="py-3 text-right font-medium"><%= item.quantity %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

    </div>
  </div>

  <!-- EDIT MODAL -->
  <dialog id="edit-modal" class="dialog">
    <div class="w-full max-w-lg space-y-4">
      <header>
        <h2 class="font-semibold text-lg">Edit Rincian Barang</h2>
        <p class="text-sm text-muted-foreground">Ubah rincian barang permintaan.</p>
      </header>
      <div id="modal-error-alert" class="bg-destructive/15 text-destructive text-sm p-3 rounded-lg border border-destructive/20 hidden"></div>
      <form id="edit-form" class="space-y-4" onsubmit="window.submitEdit(event)">
        <div class="grid gap-2">
          <div class="flex justify-between items-center gap-4">
            <label class="text-sm font-medium">Barang Permintaan <span class="text-destructive">*</span></label>
            <button type="button" onclick="window.addEditRow()" class="btn-xs-outline">Tambah Barang</button>
          </div>
          <div style="max-height: 16rem; overflow-y: auto;">
            <table class="w-full text-left text-sm" id="edit-items-table">
              <thead>
                <tr class="border-b text-muted-foreground">
                  <th class="pb-2 w-[40px] font-medium">No</th>
                  <th class="pb-2 font-medium">Nama Barang</th>
                  <th class="pb-2 w-[110px] font-medium">Qty</th>
                  <th class="pb-2 w-[44px] text-right"></th>
                </tr>
              </thead>
              <tbody class="divide-y" id="edit-items-tbody"></tbody>
            </table>
          </div>
        </div>
        <footer class="flex justify-end gap-2 pt-2 border-t">
          <button type="button" onclick="window.closeEditModal()" class="btn-outline">Batal</button>
          <button type="submit" class="btn">Simpan</button>
        </footer>
      </form>
    </div>
  </dialog>

  <!-- DELETE CONFIRMATION MODAL -->
  <dialog id="delete-modal" class="dialog">
    <div class="w-full max-w-sm space-y-4">
      <header>
        <h2 class="font-semibold text-lg text-destructive">Konfirmasi Hapus</h2>
        <p class="text-sm text-muted-foreground">Apakah Anda yakin ingin menghapus berkas permintaan barang ini? Tindakan ini tidak dapat dibatalkan.</p>
      </header>
      <footer class="flex justify-end gap-2 pt-2">
        <button type="button" onclick="window.closeDeleteModal()" class="btn-outline">Batal</button>
        <button type="button" onclick="window.submitDelete()" class="btn bg-destructive hover:bg-destructive/90 text-white">Hapus Berkas</button>
      </footer>
    </div>
  </dialog>

  <script>
    (() => {
      // Modal Delete logic
      window.openDeleteModal = function() {
        const modal = document.getElementById('delete-modal');
        if (modal) {
          modal.showModal();
        }
      };

      window.closeDeleteModal = function() {
        const modal = document.getElementById('delete-modal');
        if (modal) {
          modal.close();
        }
      };

      window.submitDelete = async function() {
        window.closeDeleteModal();
        try {
          const response = await fetch('/procurement/<%= procurement.id %>/delete', { method: 'POST' });
          const result = await response.json();
          if(result.success) {
            if (window.showToast) {
              window.showToast('Sukses', result.message, 'success');
            } else {
              alert(result.message);
            }
            setTimeout(() => {
              window.location.href = '/procurement';
            }, 1000);
          } else {
            if (window.showToast) {
              window.showToast('Gagal', result.message || 'Gagal menghapus permohonan.', 'error');
            } else {
              alert(result.message || 'Gagal menghapus permohonan.');
            }
          }
        } catch (err) {
          console.error(err);
          if (window.showToast) {
            window.showToast('Error', 'Terjadi kesalahan jaringan.', 'error');
          } else {
            alert('Terjadi kesalahan jaringan.');
          }
        }
      };

      // Modal Edit logic
      let editRowCount = 0;
      
      window.openEditModal = function() {
        const modal = document.getElementById('edit-modal');
        if (!modal) return;
        modal.showModal();

        // Populate items table
        const tbody = document.getElementById('edit-items-tbody');
        tbody.innerHTML = '';
        editRowCount = 0;

        <% items.forEach(item => { %>
          window.addEditRow('<%= item.item_name %>', <%= item.quantity %>);
        <% }) %>
      };

      window.closeEditModal = function() {
        const modal = document.getElementById('edit-modal');
        if (modal) {
          modal.close();
        }
        const alertEl = document.getElementById('modal-error-alert');
        if (alertEl) {
          alertEl.classList.add('hidden');
        }
      };

      window.addEditRow = function(name = '', qty = 1) {
        editRowCount++;
        const tbody = document.getElementById('edit-items-tbody');
        const tr = document.createElement('tr');
        tr.id = `edit-item-row-${editRowCount}`;
        tr.className = 'hover:bg-muted/10';
        
        tr.innerHTML = `
          <td class="py-2 text-muted-foreground edit-row-index align-middle">${tbody.children.length + 1}</td>
          <td class="py-1 pr-2 align-middle">
            <input type="text" name="item_name" class="input w-full" placeholder="Nama barang..." value="${name}" required />
          </td>
          <td class="py-1 pr-2 align-middle">
            <input type="number" name="quantity" class="input w-full" min="1" placeholder="Qty" value="${qty}" required />
          </td>
          <td class="py-1 align-middle text-right">
            <button type="button" onclick="window.removeEditRow(${editRowCount})" class="btn-xs-icon-ghost text-destructive hover:bg-destructive/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </td>
        `;
        tbody.appendChild(tr);
      };

      window.removeEditRow = function(id) {
        const row = document.getElementById(`edit-item-row-${id}`);
        if(row) {
          row.remove();
          window.recalculateEditIndices();
        }
      };

      window.recalculateEditIndices = function() {
        const indices = document.querySelectorAll('.edit-row-index');
        indices.forEach((el, index) => {
          el.innerText = index + 1;
        });
      };

      window.submitEdit = async function(event) {
        event.preventDefault();
        
        const form = document.getElementById('edit-form');
        const formData = new URLSearchParams(new FormData(form));

        try {
          const response = await fetch('/procurement/<%= procurement.id %>/edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formData.toString()
          });
          const result = await response.json();
          if(result.success) {
            window.closeEditModal();
            if (window.showToast) {
              window.showToast('Sukses', result.message, 'success');
            } else {
              alert(result.message);
            }
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          } else {
            const alertEl = document.getElementById('modal-error-alert');
            if (alertEl) {
              alertEl.innerText = result.message || 'Gagal memperbarui berkas.';
              alertEl.classList.remove('hidden');
            }
          }
        } catch (err) {
          console.error(err);
          if (window.showToast) {
            window.showToast('Error', 'Terjadi kesalahan jaringan.', 'error');
          } else {
            alert('Terjadi kesalahan jaringan.');
          }
        }
      };
    })();
  </script>
</main>

<%- include('../partials/footer') %>
