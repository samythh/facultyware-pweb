<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto">
      
      <!-- Breadcrumb & Title -->
      <div class="mb-6 flex flex-col gap-2">
        <div class="flex items-center gap-1.5 text-xs text-muted-foreground" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <a href="/procurement" class="hover:text-foreground">Permintaan Barang</a>
          <span>/</span>
          <span class="text-foreground">Buat Baru</span>
        </div>
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Buat Permintaan Barang Baru</h1>
        <p class="text-sm text-muted-foreground">Tambahkan rincian barang yang ingin diajukan untuk pengadaan.</p>
      </div>

      <!-- Error Alert -->
      <% if (error) { %>
        <div class="bg-destructive/15 text-destructive text-sm p-4 rounded-xl border border-destructive/20 mb-6 flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <div>
            <h5 class="font-semibold leading-tight">Error pengisian form</h5>
            <p class="mt-1 opacity-90"><%= error %></p>
          </div>
        </div>
      <% } %>

      <form action="/procurement/create" method="POST" id="procurement-form" class="space-y-6">

        <!-- Judul Card -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm space-y-2">
          <label for="title" class="text-base font-semibold">Judul Permintaan</label>
          <input type="text" id="title" name="title" class="input w-full" placeholder="Mis. Kebutuhan Lab Komputer (opsional)" />
          <p class="text-xs text-muted-foreground">Kosongkan untuk memakai ringkasan otomatis dari daftar barang.</p>
        </div>

        <!-- Items Card -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm space-y-4">
          <div class="flex justify-between items-center gap-4">
            <h3 class="text-base font-semibold">Daftar Barang Permintaan <span class="text-destructive">*</span></h3>
            <button type="button" onclick="window.addItemRow()" class="btn-xs-outline inline-flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              Tambah Baris
            </button>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm" id="items-table">
              <thead>
                <tr class="border-b text-muted-foreground font-semibold">
                  <th class="pb-3 w-[50px]">No</th>
                  <th class="pb-3 pr-4">Nama Barang</th>
                  <th class="pb-3 pr-4 w-[180px]">Jumlah (Quantity)</th>
                  <th class="pb-3 w-[80px] text-right">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y" id="items-tbody">
                <!-- Dynamic rows will be inserted here -->
              </tbody>
            </table>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex justify-end gap-3">
          <a href="/procurement" class="btn-outline" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Batal</a>
          <button type="submit" class="btn">Kirim Permintaan</button>
        </div>
      </form>

    </div>
  </div>

  <!-- Table row dynamic javascript template -->
  <script>
    (() => {
      let rowCount = 0;

      window.addItemRow = function(name = '', qty = 1) {
        rowCount++;
        const tbody = document.getElementById('items-tbody');
        
        const tr = document.createElement('tr');
        tr.id = `item-row-${rowCount}`;
        tr.className = 'hover:bg-muted/10';

        tr.innerHTML = `
          <td class="py-3 font-medium align-middle row-index">${tbody.children.length + 1}</td>
          <td class="py-2 pr-4 align-middle">
            <input type="text" name="item_name" class="input w-full" placeholder="Nama barang..." value="${name}" required />
          </td>
          <td class="py-2 pr-4 align-middle">
            <input type="number" name="quantity" class="input w-full" min="1" placeholder="Qty" value="${qty}" required />
          </td>
          <td class="py-2 align-middle text-right">
            <button type="button" onclick="window.removeItemRow(${rowCount})" class="btn-xs-icon-ghost text-destructive hover:bg-destructive/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                <line x1="10" y1="11" x2="10" y2="17"></line>
                <line x1="14" y1="11" x2="14" y2="17"></line>
              </svg>
            </button>
          </td>
        `;

        tbody.appendChild(tr);
      };

      window.removeItemRow = function(id) {
        const row = document.getElementById(`item-row-${id}`);
        if (row) {
          row.remove();
          window.recalculateIndices();
        }
      };

      window.recalculateIndices = function() {
        const indices = document.querySelectorAll('.row-index');
        indices.forEach((el, index) => {
          el.innerText = index + 1;
        });
      };

      // Form validation before submission
      document.getElementById('procurement-form').addEventListener('submit', function(e) {
        const rows = document.querySelectorAll('#items-tbody tr');
        if (rows.length === 0) {
          e.preventDefault();
          if (window.showToast) {
            window.showToast('Validasi Gagal', 'Tambahkan minimal 1 barang permintaan.', 'error');
          } else {
            alert('Tambahkan minimal 1 barang permintaan.');
          }
        }
      });

      // Add initial row on load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => window.addItemRow());
      } else {
        window.addItemRow();
      }
    })();
  </script>
</main>

<%- include('../partials/footer') %>
