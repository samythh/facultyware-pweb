<%
  var st = (typeof error !== 'undefined' && error && error.status) ? error.status : 500;
  var msg = (typeof message !== 'undefined' && message) ? message : 'Terjadi kesalahan tak terduga.';
  var stk = (typeof error !== 'undefined' && error && error.stack) ? error.stack : '';
  var meta = {
    403: { title: 'Akses Ditolak',            sub: 'Kamu tidak punya hak akses untuk membuka halaman ini.' },
    404: { title: 'Halaman Tidak Ditemukan',  sub: 'Halaman atau data yang kamu cari tidak ada.' },
    409: { title: 'Terjadi Konflik',          sub: 'Aksi ini bentrok dengan kondisi data saat ini.' },
    500: { title: 'Terjadi Kesalahan',        sub: 'Ada masalah di server. Coba lagi beberapa saat.' }
  };
  var info = meta[st] || meta[500];
%>
<%- include('partials/header', { title: info.title }) %>

<main id="content" class="min-h-screen flex items-center justify-center p-4 md:p-6">
  <div class="card bg-card rounded-2xl border shadow-sm w-full max-w-md p-8 text-center">
    <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-red-50 text-red-500">
      <% if (st === 403) { %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
      <% } else if (st === 404) { %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path><line x1="11" x2="11" y1="8" y2="14"></line><line x1="8" x2="14" y1="11" y2="11"></line></svg>
      <% } else { %>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><line x1="12" x2="12" y1="9" y2="13"></line><line x1="12" x2="12.01" y1="17" y2="17"></line></svg>
      <% } %>
    </div>

    <p class="text-5xl font-bold tracking-tight text-foreground"><%= st %></p>
    <h1 class="mt-2 text-xl font-semibold text-foreground"><%= info.title %></h1>
    <p class="mt-2 text-sm text-muted-foreground"><%= info.sub %></p>

    <% if (msg && msg !== info.title) { %>
      <div class="mt-4 rounded-lg border bg-muted/40 px-4 py-3 text-sm text-foreground">
        <%= msg %>
      </div>
    <% } %>

    <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
      <a class="btn" href="/">Kembali ke Beranda</a>
      <% if (st === 403) { %>
        <a class="btn-outline border-red-500 text-red-500 hover:bg-red-50 hover:text-red-600" href="/logout">Ganti Akun</a>
      <% } else { %>
        <a class="btn-outline" href="javascript:history.back()">Kembali</a>
      <% } %>
    </div>

    <% if (stk) { %>
      <details class="mt-6 text-left">
        <summary class="cursor-pointer text-xs text-muted-foreground">Detail teknis (mode pengembangan)</summary>
        <pre class="mt-2 overflow-auto rounded-lg bg-muted p-3 text-xs text-muted-foreground"><%= stk %></pre>
      </details>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
