<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<main id="content">
  <%- include('partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      <header class="flex flex-wrap items-end justify-between gap-4">
        <div class="flex flex-col gap-2">
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl"><%= title %></h1>
          <p class="text-muted-foreground">
            Persetujuan tahap kedua: tinjau harga &amp; anggaran sebelum menyetujui Purchase Order.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <input type="text" id="search-input" placeholder="Cari No PO, supplier, atau judul..." class="input" style="min-width: 240px;" />
          <%- include('partials/sort-control', { action: '/approval/po', current: (typeof sort !== 'undefined' ? sort : ''), opts: (typeof sortOptions !== 'undefined' ? sortOptions : []), keep: {} }) %>
        </div>
      </header>

      <div class="card card--table overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="bg-muted/50 border-b">
                <th class="p-4 font-semibold text-muted-foreground w-[180px]">No PO</th>
                <th class="p-4 font-semibold text-muted-foreground w-[150px]">Tanggal</th>
                <th class="p-4 font-semibold text-muted-foreground">Supplier</th>
                <th class="p-4 font-semibold text-muted-foreground text-right w-[160px]">Total</th>
                <th class="p-4 font-semibold text-muted-foreground w-[150px]">Status</th>
                <th class="p-4 font-semibold text-muted-foreground w-[100px] text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <% if (purchases && purchases.length > 0) { %>
                <% purchases.forEach(function (po) { %>
                  <tr class="hover:bg-muted/30 transition-colors cursor-pointer" onclick="window.location.href='/purchase/<%= po.id %>'">
                    <td class="p-4">
                      <span class="font-mono font-semibold text-primary block"><%= po.purchase_number %></span>
                      <span class="text-xs text-muted-foreground block mt-0.5 max-w-[240px] truncate" title="<%= po.judul %>"><%= po.judul %></span>
                    </td>
                    <td class="p-4 text-muted-foreground"><%= new Date(po.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                    <td class="p-4 font-medium"><%= po.supplier || '-' %></td>
                    <td class="p-4 text-right font-mono font-semibold text-primary">Rp <%= Number(po.total || 0).toLocaleString('id-ID') %></td>
                    <td class="p-4"><%- include('partials/status-badge', { status: po.status }) %></td>
                    <td class="p-4 text-right">
                      <a href="/purchase/<%= po.id %>" class="btn-action-view" onclick="event.stopPropagation()">Tinjau</a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="p-8 text-center text-muted-foreground">
                    Tidak ada Purchase Order yang menunggu persetujuan.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div id="pagination-container" class="flex items-center justify-between border-t px-4 py-4 text-sm text-muted-foreground">
          <span id="page-info">Menampilkan <%= purchases ? purchases.length : 0 %> PO menunggu persetujuan</span>

          <div class="flex items-center gap-2" id="pagination-buttons">
            <button type="button" id="btn-prev" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-500 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:bg-gray-50 disabled:cursor-not-allowed select-none transition-colors" disabled>Sebelumnya</button>
            <div id="page-numbers" class="flex gap-2"></div>
            <button type="button" id="btn-next" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-medium text-gray-500 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:bg-gray-50 disabled:cursor-not-allowed select-none transition-colors" disabled>Berikutnya</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/list-search-pagination') %>
</main>

<%- include('partials/footer') %>
