<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-md mx-auto">
      
      <div class="mb-6 flex flex-col gap-2">
        <div class="flex items-center gap-1.5 text-xs text-muted-foreground" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <a href="/supplier" class="hover:text-foreground">Kelola Supplier</a>
          <span>/</span>
          <span class="text-foreground">Tambah Baru</span>
        </div>
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Tambah Supplier Baru</h1>
        <p class="text-sm text-muted-foreground">Isi detail informasi supplier untuk didaftarkan di sistem.</p>
      </div>

      <% if (error) { %>
        <div class="bg-destructive/15 text-destructive text-sm p-4 rounded-xl border border-destructive/20 mb-6 flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <div>
            <h5 class="font-semibold leading-tight">Gagal menyimpan data</h5>
            <p class="mt-1 opacity-90"><%= error %></p>
          </div>
        </div>
      <% } %>

      <form action="/supplier/create" method="POST" class="card p-6 bg-card rounded-xl border shadow-sm space-y-6">
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="grid gap-2">
            <label for="code" class="text-sm font-medium">Kode Supplier <span class="text-destructive">*</span></label>
            <input type="text" name="code" id="code" placeholder="Contoh: SPL-001" value="<%= supplier.code || '' %>" class="input w-full" required />
          </div>
          <div class="grid gap-2">
            <label for="name" class="text-sm font-medium">Nama Supplier <span class="text-destructive">*</span></label>
            <input type="text" name="name" id="name" placeholder="Contoh: PT. Andalas Prima" value="<%= supplier.name || '' %>" class="input w-full" required />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="grid gap-2">
            <label for="phone" class="text-sm font-medium">No. Telepon</label>
            <input type="text" name="phone" id="phone" placeholder="Contoh: 081234567890" value="<%= supplier.phone || '' %>" class="input w-full" />
          </div>
          <div class="grid gap-2">
            <label for="email" class="text-sm font-medium">Email</label>
            <input type="email" name="email" id="email" placeholder="Contoh: sales@supplier.com" value="<%= supplier.email || '' %>" class="input w-full" />
          </div>
        </div>

        <div class="grid gap-2">
          <label for="address" class="text-sm font-medium">Alamat Pemasok</label>
          <textarea name="address" id="address" placeholder="Tuliskan alamat lengkap supplier..." class="input w-full" rows="4" ><%= supplier.address || '' %></textarea>
        </div>

        <div class="flex justify-end gap-3 border-t pt-4">
          <a href="/supplier" class="btn-outline" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Batal</a>
          <button type="submit" class="btn">Simpan Supplier</button>
        </div>
      </form>

    </div>
  </div>



<style>
  textarea.input {
    display: block;
    width: 100%;
    appearance: none;
    border-radius: var(--radius-md);
    border-width: 1px;
    border-style: solid;
    border-color: var(--color-input);
    background-color: transparent;
    padding-inline: calc(var(--spacing) * 3);
    padding-block: calc(var(--spacing) * 2);
    font-size: var(--text-base);
    line-height: var(--tw-leading, var(--text-base--line-height));
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    transition-property: color, box-shadow;
    transition-duration: 150ms;
    outline: none;
    resize: vertical;
    font-family: inherit;
    color: var(--color-foreground);
  }
  textarea.input::placeholder {
    color: var(--color-muted-foreground);
  }
  textarea.input:focus {
    border-color: var(--color-ring);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-ring) 20%, transparent),
                0 1px 2px 0 rgb(0 0 0 / 0.05);
  }
</style>

</main>

<%- include('../partials/footer') %>
