<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto">

      <!-- Breadcrumb & Title -->
      <div class="mb-6 flex flex-col gap-2">
        <div class="flex items-center gap-1.5 text-xs text-muted-foreground" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <a href="/pengadaan" class="hover:text-foreground">Pengadaan Barang</a>
          <span>/</span>
          <span class="text-foreground">Buat Pengadaan</span>
        </div>
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Buat Pengadaan Baru</h1>
        <p class="text-sm text-muted-foreground">Gabungkan satu atau beberapa permintaan disetujui menjadi satu paket pengadaan.</p>
      </div>

      <% if (locals.error) { %>
        <div class="bg-destructive/15 text-destructive text-sm p-4 rounded-xl border border-destructive/20 mb-6 flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <div>
            <h5 class="font-semibold leading-tight">Gagal Membuat Pengadaan</h5>
            <p class="mt-1 opacity-90"><%= error %></p>
          </div>
        </div>
      <% } %>

      <% if (!requests || requests.length === 0) { %>
        <div class="card p-6 bg-card rounded-xl border shadow-sm text-center py-12 text-muted-foreground text-sm">
          Tidak ada permintaan disetujui yang menunggu pengadaan.
        </div>
      <% } else { %>
      <form method="post" action="/pengadaan/create" class="space-y-6">

        <!-- Judul paket -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm space-y-4">
          <h3 class="text-base font-semibold">Informasi Pengadaan</h3>
          <div class="grid gap-2">
            <label for="title" class="text-sm font-medium">Judul Paket Pengadaan <span class="text-destructive">*</span></label>
            <input type="text" id="title" name="title" placeholder="Mis. Pengadaan IT - Juni 2026" class="input w-full" required />
          </div>
        </div>

        <!-- Pilih permintaan (multi) -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm space-y-4">
          <div class="flex items-center justify-between">
            <h3 class="text-base font-semibold">Pilih Permintaan untuk Digabung <span class="text-destructive">*</span></h3>
            <span id="selCount" class="text-xs text-muted-foreground">0 dipilih</span>
          </div>

          <div class="space-y-3">
            <% requests.forEach(function (r) { %>
              <label class="flex gap-3 items-start rounded-xl border p-4 cursor-pointer hover:bg-muted/10 transition">
                <input type="checkbox" name="request_number" value="<%= r.request_number %>" class="req-check mt-1" />
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="font-semibold text-sm"><%= r.title || 'Tanpa judul' %></span>
                    <span class="text-xs rounded-full bg-muted px-2 py-0.5"><%= r.items.length %> barang</span>
                  </div>
                  <div class="mt-0.5 flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                    <span class="font-mono"><%= r.request_number %></span>
                    <span>&middot;</span>
                    <span><%= r.requester_name || 'Staf' %></span>
                    <span>&middot;</span>
                    <span><%= fmtDate(r.request_date) %></span>
                  </div>
                  <ul class="mt-2 text-sm text-muted-foreground list-disc pl-5">
                    <% r.items.forEach(function (it) { %>
                      <li><%= it.item_name %> <span class="font-mono">&times;<%= it.quantity %></span></li>
                    <% }) %>
                  </ul>
                </div>
              </label>
            <% }) %>
          </div>
        </div>

        <!-- Actions -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm flex items-center justify-end gap-2">
          <a href="/pengadaan" class="btn-outline" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Batal</a>
          <button type="submit" class="btn">Simpan Pengadaan</button>
        </div>
      </form>
      <% } %>

    </div>
  </div>
</main>

<script>
  (function () {
    const counter = document.getElementById('selCount');
    function update() {
      const n = document.querySelectorAll('.req-check:checked').length;
      if (counter) counter.textContent = n + ' dipilih';
    }
    document.querySelectorAll('.req-check').forEach(function (c) {
      c.addEventListener('change', update);
    });
    update();
  })();
</script>

<%- include('../partials/footer') %>
