<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto">
      
      <!-- Breadcrumb & Title -->
      <div class="mb-6 flex flex-col gap-2">
        <div class="flex items-center gap-1.5 text-xs text-muted-foreground" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <a href="/pengadaan" class="hover:text-foreground">Pengadaan Barang</a>
          <span>/</span>
          <span class="text-foreground">Buat Pengadaan</span>
        </div>
        <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Buat Pengadaan Baru</h1>
        <p class="text-sm text-muted-foreground">Pilih permintaan disetujui yang belum diproses untuk dibuatkan pengadaannya.</p>
      </div>

      <% if (locals.error) { %>
        <div class="bg-destructive/15 text-destructive text-sm p-4 rounded-xl border border-destructive/20 mb-6 flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <div>
            <h5 class="font-semibold leading-tight">Gagal Membuat Pengadaan</h5>
            <p class="mt-1 opacity-90"><%= error %></p>
          </div>
        </div>
      <% } %>

      <form method="post" action="/pengadaan/create" class="space-y-6">
        
        <!-- Main Form Card -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm space-y-4">
          <h3 class="text-base font-semibold">Informasi Pengadaan</h3>
          
          <div class="grid gap-2">
            <label for="request_number" class="text-sm font-medium">Permintaan Asal (Approved) <span class="text-destructive">*</span></label>
            <select name="request_number" id="request_number" class="select w-full" required>
              <option value="">-- Pilih Permintaan Asal --</option>
              <% requests.forEach(function (r) { %>
                <option value="<%= r.request_number %>" data-title="Pengadaan untuk <%= r.request_number %> - <%= r.first_item_name %>"><%= r.request_number %> (<%= r.requester_name %> - <%= fmtDate(r.request_date) %>)</option>
              <% }) %>
            </select>
          </div>

          <div class="grid gap-2">
            <label for="title" class="text-sm font-medium">Judul Pengadaan <span class="text-destructive">*</span></label>
            <input type="text" id="title" name="title" placeholder="Masukkan judul pengadaan barang..." class="input w-full" required />
          </div>
        </div>

        <!-- Dynamic Items Container -->
        <div id="request_items">
          <div class="card p-6 bg-card rounded-xl border shadow-sm text-center py-8 text-muted-foreground text-sm">
            Silakan pilih nomor permintaan asal di atas untuk memuat daftar barang.
          </div>
        </div>

        <!-- Actions Card -->
        <div class="card p-6 bg-card rounded-xl border shadow-sm flex flex-col sm:flex-row items-center justify-end gap-4">
          <div class="flex items-center gap-2 w-full sm:w-auto justify-end">
            <a href="/pengadaan" class="btn-outline" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Batal</a>
            <button type="submit" class="btn">Simpan &amp; Ajukan Pengadaan</button>
          </div>
        </div>

      </form>
    </div>
  </div>
</main>

<script>
  document.getElementById('request_number').addEventListener('change', async function () {
    const requestNumber = this.value;
    const titleInput = document.getElementById('title');
    const target = document.getElementById('request_items');
    target.innerHTML = '';
    
    if (!requestNumber) {
      titleInput.value = '';
      target.innerHTML = `
        <div class="card p-6 bg-card rounded-xl border shadow-sm text-center py-8 text-muted-foreground text-sm">
          Silakan pilih nomor permintaan asal di atas untuk memuat daftar barang.
        </div>`;
      return;
    }

    // Set default title based on selected request
    const selectedOption = this.options[this.selectedIndex];
    titleInput.value = selectedOption.dataset.title || '';

    try {
      const res = await fetch(`/pengadaan/api/request/${requestNumber}/items`);
      if (!res.ok) throw new Error('Fetch request items failed');
      const data = await res.json();
      
      if (!data.items || !data.items.length) {
        target.innerHTML = `
          <div class="card p-6 bg-card rounded-xl border shadow-sm text-center py-8 text-muted-foreground text-sm">
            Tidak ada item dalam permintaan ini.
          </div>`;
        return;
      }
      
      const wrapper = document.createElement('div');
      wrapper.className = 'card p-6 bg-card rounded-xl border shadow-sm space-y-4';
      wrapper.innerHTML = '<h3 class="text-base font-semibold">Daftar Rincian Barang</h3>';
      
      const tableWrap = document.createElement('div');
      tableWrap.className = 'overflow-x-auto';
      
      const table = document.createElement('table');
      table.className = 'w-full text-left text-sm border-collapse';
      table.innerHTML = `
        <thead>
          <tr class="border-b text-muted-foreground font-semibold">
            <th class="pb-3 pr-4">Nama Barang</th>
            <th class="pb-3 text-right w-[150px]">Jumlah (Quantity)</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          ${data.items.map(i => `
            <tr class="hover:bg-muted/10">
              <td class="py-3 font-medium align-middle text-foreground">${i.name}</td>
              <td class="py-3 text-right align-middle font-mono font-medium text-muted-foreground">${i.quantity}</td>
            </tr>`).join('')}
        </tbody>
      `;
      tableWrap.appendChild(table);
      wrapper.appendChild(tableWrap);
      target.appendChild(wrapper);
    } catch (e) {
      target.innerHTML = `
        <div class="card p-6 bg-card rounded-xl border border-destructive/20 text-destructive text-center py-8 text-sm">
          Gagal memuat item barang. Silakan pilih ulang nomor permintaan asal.
        </div>`;
    }
  });
</script>

<%- include('../partials/footer') %>
