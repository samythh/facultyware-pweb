<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      
      <!-- Breadcrumb & Actions -->
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-1.5 text-xs text-muted-foreground" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <a href="/pengadaan" class="hover:text-foreground">Pengadaan Barang</a>
          <span>/</span>
          <span class="text-foreground"><%= procurement.request_number %></span>
        </div>
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <div>
            <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Detail Pengadaan Barang</h1>
            <p class="text-sm text-muted-foreground">Rincian data pengadaan yang diusulkan beserta status approval.</p>
          </div>
          <div class="flex gap-2 shrink-0">
            <% if (procurement.status === 'submitted') { %>
              <form method="POST" action="/pengadaan/<%= procurement.id %>/approve" class="inline">
                <button type="submit" class="btn bg-emerald-600 hover:bg-emerald-700 text-white">Setujui Pengadaan</button>
              </form>
              <form method="POST" action="/pengadaan/<%= procurement.id %>/reject" class="inline">
                <button type="submit" class="btn bg-rose-600 hover:bg-rose-700 text-white">Tolak Pengadaan</button>
              </form>
            <% } %>
            <a href="/pengadaan" class="btn-outline inline-flex items-center" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
              Kembali
            </a>
          </div>
        </div>
      </div>

      <!-- Info Pengadaan Grid Card -->
      <div class="card p-6 bg-card rounded-xl border shadow-sm space-y-4">
        <h3 class="text-base font-semibold">Informasi Pengadaan</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="flex flex-col gap-1.5">
            <span class="text-xs uppercase tracking-wider text-muted-foreground">Nomor Permintaan Asal</span>
            <span class="font-bold font-mono text-primary text-base"><%= procurement.request_number %></span>
          </div>
          <div class="flex flex-col gap-1.5 col-span-2">
            <span class="text-xs uppercase tracking-wider text-muted-foreground">Judul Pengadaan</span>
            <span class="font-semibold text-foreground text-base"><%= procurement.title %></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <span class="text-xs uppercase tracking-wider text-muted-foreground">Status Pengadaan</span>
            <span><%- include('../partials/status-badge', { status: procurement.status }) %></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <span class="text-xs uppercase tracking-wider text-muted-foreground">Tanggal Permintaan Asal</span>
            <span class="font-medium text-foreground text-base"><%= fmtDate(procurement.request_date) %></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <span class="text-xs uppercase tracking-wider text-muted-foreground">Pemohon Permintaan</span>
            <span class="font-medium text-foreground text-base"><%= procurement.requester_name || '-' %></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <span class="text-xs uppercase tracking-wider text-muted-foreground">Pembuat Pengadaan</span>
            <span class="font-medium text-foreground text-base"><%= procurement.creator_name || '-' %></span>
          </div>
          <div class="flex flex-col gap-1.5">
            <span class="text-xs uppercase tracking-wider text-muted-foreground">Disetujui Tanggal</span>
            <span class="font-medium text-foreground text-base"><%= fmtDate(procurement.approved_at) %></span>
          </div>
        </div>
      </div>

      <!-- Item Table Card -->
      <div class="card p-6 bg-card rounded-xl border shadow-sm space-y-4">
        <h3 class="text-base font-semibold">Rincian Barang yang Diajukan</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm border-collapse">
            <thead>
              <tr class="border-b text-muted-foreground font-semibold">
                <th class="pb-3 pr-4">Nama Barang</th>
                <th class="pb-3 text-right w-[150px]">Jumlah (Quantity)</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <% items.forEach(function (it) { %>
                <tr class="hover:bg-muted/10">
                  <td class="py-3 font-medium align-middle text-foreground">
                    <%= it.item_name %>
                    <% if (it.item_code) { %>
                      <span class="text-xs font-mono text-muted-foreground bg-muted px-1.5 py-0.5 rounded ml-2"><%= it.item_code %></span>
                    <% } %>
                  </td>
                  <td class="py-3 text-right align-middle font-mono font-medium text-primary"><%= it.quantity %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
