<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<main id="content">
  <%- include('../partials/navbar') %>

  <div class="p-4 md:p-6 xl:p-12">
    <div class="max-w-screen-lg mx-auto flex flex-col gap-6">
      
      <!-- Top Title and Create Button -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Pengadaan Barang</h1>
          <p class="text-sm text-muted-foreground">Kelola proses pengadaan barang dari permintaan yang disetujui.</p>
        </div>
        <a href="/pengadaan/create" class="btn shrink-0" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Buat Pengadaan
        </a>
      </div>

      <!-- Search & Sort Card -->
      <div class="card p-4 bg-card rounded-xl border shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <form method="get" action="/pengadaan" class="flex gap-2" style="flex:1 1 260px;" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
            <div class="relative flex-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-muted-foreground">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input type="text" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" placeholder="Cari berdasarkan nomor permintaan atau judul pengadaan..." class="input w-full" style="padding-left: 2.5rem !important;" />
            </div>
            <input type="hidden" name="sort" value="<%= typeof sort !== 'undefined' ? sort : '' %>" />
            <button type="submit" class="btn-outline">Cari</button>
            <% if (typeof search !== 'undefined' && search) { %>
              <a href="/pengadaan?sort=<%= typeof sort !== 'undefined' ? sort : '' %>" class="btn-ghost" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Clear</a>
            <% } %>
          </form>
          <%- include('../partials/sort-control', { action: '/pengadaan', current: (typeof sort !== 'undefined' ? sort : ''), opts: (typeof sortOptions !== 'undefined' ? sortOptions : []), keep: { search: (typeof search !== 'undefined' ? search : '') } }) %>
        </div>
      </div>

      <!-- Table Card -->
      <div class="card card--table bg-card rounded-xl border shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="bg-muted/50 border-b">
                <th class="p-4 font-semibold text-muted-foreground w-[60px]">No</th>
                <th class="p-4 font-semibold text-muted-foreground w-[180px]">No. Pengadaan</th>
                <th class="p-4 font-semibold text-muted-foreground">Judul Pengadaan</th>
                <th class="p-4 font-semibold text-muted-foreground w-[150px]">Pembuat</th>
                <th class="p-4 font-semibold text-muted-foreground w-[160px]">Permintaan Digabung</th>
                <th class="p-4 font-semibold text-muted-foreground w-[150px]">Status</th>
                <th class="p-4 font-semibold text-muted-foreground w-[100px] text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              <% if (procurements && procurements.length) { %>
                <% procurements.forEach(function (proc, idx) { %>
                  <tr class="hover:bg-muted/30 transition-colors">
                    <td class="p-4 font-medium text-muted-foreground"><%= ((currentPage - 1) * limit) + idx + 1 %></td>
                    <td class="p-4 font-mono font-semibold text-primary"><%= proc.request_number %></td>
                    <td class="p-4 font-medium"><%= proc.title %></td>
                    <td class="p-4 text-muted-foreground"><%= proc.creator_name || '-' %></td>
                    <td class="p-4 text-muted-foreground"><%= proc.request_count %> permintaan</td>
                    <td class="p-4"><%- include('../partials/status-badge', { status: proc.status }) %></td>
                    <td class="p-4 text-right">
                      <a href="/pengadaan/<%= proc.id %>" class="btn-xs-outline inline-flex items-center" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">
                        Detail
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="p-8 text-center text-muted-foreground">Belum ada data Pengadaan Barang.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <div class="p-4 border-t flex items-center justify-between gap-4">
            <span class="text-xs text-muted-foreground">
              Halaman <%= currentPage %> dari <%= totalPages %>
            </span>
            <div class="flex gap-2">
              <% if (currentPage > 1) { %>
                <a href="/pengadaan?page=<%= currentPage - 1 %>&search=<%= search %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" class="btn-xs-outline" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Sebelumnya</a>
              <% } %>
              <% if (currentPage < totalPages) { %>
                <a href="/pengadaan?page=<%= currentPage + 1 %>&search=<%= search %>&sort=<%= typeof sort !== 'undefined' ? sort : '' %>" class="btn-xs-outline" hx-boost="true" hx-select="#content" hx-target="#content" hx-swap="outerHTML">Selanjutnya</a>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</main>

<%- include('../partials/footer') %>
